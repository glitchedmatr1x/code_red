<scxml xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="file://t:\mc4\assets\tune\ui\scxml_mc4.xsd">
  <UIMenu id="Net_LANMenu" movie="list" inputType="rightAnalog">
      <transition event="@UI.CANCEL*RELEASED" consume="true">
          <action	expr="PlaySound('HUD_MENU_BACK_MASTER')"></action>
          <action	expr="unfocus(Net_LANMenu)"></action>
          <action	expr="Focus(NetTab_LANMode)"></action>
          <action expr="Enter(PauseMenu_Main_Prompts)"></action>
          <action expr="Exit(NetPrompts_MainMenu)"></action>
      </transition>      
    <UIButton desc="mp_fe_goto_online"  target="NetConf_PlayPublic">
      <transition event="retry_action">
        <action expr="goto(NetConf_PlayPublic)"></action>
        <action expr="NetMachine.Authenticate('Online Multiplayer')"></action>
      </transition>
    </UIButton>
    <UIButton desc="mp_fe_goto_private" target="NetConf_PlayPrivate">
      <transition event="retry_action">
        <action expr="goto(NetConf_PlayPrivate)"></action>
        <action expr="NetMachine.Authenticate('Online Multiplayer')"></action>
      </transition>
    </UIButton>
    <UIButton desc="mp_fe_exit"         target="NetConf_ExitMP"     ></UIButton>
  </UIMenu>
</scxml>
