<scxml xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="file://t:\mc4\assets\tune\ui\scxml_mc4.xsd">
  <UILayer id="NetworkingLayerOffline" movie="list">    
    <onfocused	  expr="StreamMovie('list')"></onfocused>
    <onunfocused	expr="UnstreamMovie('list')"></onunfocused>
    <onfocused	  expr="StreamMovie('topnav')"></onfocused>
    <onunfocused	expr="UnstreamMovie('topnav')"></onunfocused>
	  <onunfocused  expr="SetFlashInt('pause_main','pausetransition.visibility',0)"></onunfocused> 
    <onfocused    expr="SetFlashInt('pause_main','pausetransition.visibility',1)"></onfocused> 
    <onfocused    expr="SetFlashInt('pause_main','pausetransition.type',4)"></onfocused>
    <onhide       expr="Exit(NetConf_AvatarPicker)"></onhide>

    <transition event="codered.LANBootstrap">
      <action expr="NetMachine.SetMultiplayerModeToLaunch('LAN')"></action>
      <action expr="NetMachine.SetFreeRoamMode('Normal')"></action>
      <action expr="SendEvent('fileSetForMPLoad')"></action>
      <action expr="UIGame.ValidateNormalMode()"></action>
      <action expr="SendEvent('net.StartOnline')"></action>
      <action expr="AddDelayedEvent('loadStart',1.0)"></action>
    </transition>
    
    <!-- Setup Tabs -->
    <onfocused expr="Exclude(NetTab_Online)"  ></onfocused>
    <onfocused expr="Exclude(NetTab_Private)" ></onfocused>
    <onfocused expr="Exclude(NetTab_LAN)"     ></onfocused>
    <ifdef expr="XENON">
      <onfocused expr="Exclude(NetTab_Party)"   ></onfocused>
      <transition event="net.playingOnline" target="Include(NetTab_Party)"></transition>
    </ifdef>
    <onfocused expr="NetMachine.SendNetModeEvent(NetworkingLayerOffline)"></onfocused>
    <transition event="net.playingPublic">
      <action expr="Include(NetTab_Private)"></action>
      <action expr="Include(NetTab_LAN)"></action>
      <action expr="Enter(NetTabs)"></action>
    </transition>
    <transition event="net.playingPrivate">
      <action expr="Include(NetTab_Online)"></action>
      <action expr="Include(NetTab_LAN)"></action>
      <action expr="Enter(NetTabs)"></action>
    </transition>
    <transition event="net.modeLAN">
      <action expr="Include(NetTab_Online)"></action>
      <action expr="Include(NetTab_Private)"></action>
      <action expr="Enter(NetTabs)"></action>
    </transition>
    <transition event="net.modeSingle" target="Enter(NetOfflineTabs)"></transition>

    <onfocused expr="Exit(InboxInvite_Validating)"></onfocused>
    <onunfocused expr="Exit(InboxInvite_Validating)"></onunfocused>
    <UIProgressBar id="InboxInvite_Validating" movie="popup">
      <onactivate expr="SetFlashInt('popup','prompt.value',0)"></onactivate>
      <ondeactivate expr="SetFlashInt('popup','prompt.value',1)"></ondeactivate>
      <onactivate expr="Disable(HelpBox)"></onactivate>
      <ondeactivate expr="Enable(HelpBox)"></ondeactivate>
      <ondeactivate expr="UIGame.SetQueuePaused(1,false)"></ondeactivate>
      <onactivate expr="UIGame.SetQueuePaused(1,true)"></onactivate>

      <onactivate	expr="StreamMovie('loading')"></onactivate>
      <ondeactivate	expr="UnstreamMovie('loading')"></ondeactivate>
      <data name="icontext" expr="Save_Icon_Saving"></data>
      <data name="text" expr="Common_Synchronizing"></data>

      <onfocused	expr="OnlineInbox.AcceptInvite()"></onfocused>
      <onfocused	expr="OnlineInbox.FillList()"></onfocused>

      <transition event="net.JoinWishPosted">
        <action expr="Exit(InboxInvite_Validating)"></action>
        <action expr="goto(NetConf_JoinWish)"></action>
      </transition>

      <transition event="net.JoinWishFailed">
        <action expr="Exit(InboxInvite_Validating)"></action>
        <action expr="goto(NetAlert_FailedInviteValidation)"></action>
      </transition>

      <transition event="@UI.PREVIOUS_TAB"></transition>
      <transition event="@UI.NEXT_TAB"></transition>
      <transition event="@UI.ZOOM_OUT"></transition>
      <transition event="@UI.ZOOM_IN"></transition>
      <transition event="@UI.CANCEL*RELEASED"></transition>
      <transition event="@UI.ACCEPT*RELEASED"></transition>
    </UIProgressBar>

    <!-- ======================================= ONLINE TABS ================================================= -->

    <onunfocused expr="Exit(NetTabs)"></onunfocused>
    <NetMenu id="NetTabs"  AllowWrap="true" movie="pause_main" flashObject="menu.elements[6]">
      <onfocused expr="Enter(MPProfile)"></onfocused>
      <onunfocused expr="Exit(MPProfile)"></onunfocused>
      <onfocused expr="Select(NetPrompts_MainMenu)"></onfocused>
      <transition event="auth.success" expr="SendEvent('loadStart')"></transition>
      <transition event="@UI.ACCEPT*RELEASED" target="PlaySound('HUD_MENU_SELECT_MASTER')"></transition>

      <UIButton desc="mp_fe_avatarpicker_tab">
        <transition event="@UI.ACCEPT*RELEASED">
          <action expr="PlaySound('HUD_MENU_SELECT_MASTER')"></action>
          <action expr="goto(NetConf_AvatarPicker)"></action>
        </transition>
      </UIButton>

      <UIButton id="NetTab_Online"  desc="mp_fe_play_online_tab"  target="NetConf_PlayPublic" consume="false">
        <transition event="retry_action">
          <action expr="goto(NetConf_PlayPublic)"></action>
          <action expr="NetMachine.Authenticate('Online Multiplayer')"></action>
        </transition>
      </UIButton>

      <UIButton id="NetTab_Private" desc="mp_fe_play_private_tab" target="NetConf_PlayPrivate" consume="false">
        <transition event="retry_action">
          <action expr="goto(NetConf_PlayPrivate)"></action>
          <action expr="NetMachine.Authenticate('Online Multiplayer')"></action>
        </transition>
      </UIButton>

      <ifdef expr="PSN">
        <data name="messages" expr="NetTab_Inbox"></data>
        <transition event="PM.UnfocusInbox">
          <action expr="Exit(Net_ContentLayer)"></action>
          <action expr="Focus(NetTabs)"></action>
          <action expr="Enter(MPProfile)"></action>
        </transition>
        <UILabel  id="NetTab_Inbox"   desc="net_invites_tab">
          <transition event="@UI.ACCEPT*RELEASED" consume="false">
            <action expr="Unfocus(NetTabs)"></action>
            <action expr="Exit(MPProfile)"></action>
            <action expr="Enter(Net_ContentLayer)"></action>
            <action expr="Select(OnlineInbox)"></action>
          </transition>
        </UILabel>
      </ifdef>

      <UILabel  id="NetTab_LAN"     desc="mp_fe_play_lan_tab"       target="NetConf_PlayLAN" consume="false"></UILabel>

      <ifdef expr="XENON">
        <data name="partyinvite" expr="NetTab_Invite"></data>
        <UILabel id="NetTab_Invite" desc="mp_fe_partyinviteui_tab"  target="NetScene.SendInvitesToParty()"  consume="false">
          <transition event="net.success"                   target="NetAlert_PartyInviteSuccess"      ></transition>
          <transition event="net.error"                     target="NetAlert_PartyInviteError"        ></transition>
          <transition event="net.fail"                      target="NetAlert_PartyInviteFail"         ></transition>
          <transition event="net.fail_PartyAlreadyJoined"   target="NetAlert_PartyInviteAlreadyJoined"></transition>
        </UILabel>
        <UIButton id="NetTab_Party" desc="mp_fe_partyui_tab"        target="NetScene.ShowCommunityUI()" consume="false"></UIButton>
      </ifdef>

      <UIButton id="NetTab_Exit"    desc="mp_fe_exit_tab"           target="NetConf_ExitMP"             consume="false"></UIButton>
    </NetMenu>

    <!-- ======================================= OFFLINE TABS ================================================= -->

    <onunfocused expr="Exit(NetOfflineTabs)"></onunfocused>
    <NetMenu id="NetOfflineTabs"  AllowWrap="true" movie="pause_main" flashObject="menu.elements[6]">
      <onfocused expr="Select(NetPrompts_MainMenu)"></onfocused>
      <onfocused expr="Activate(Net_ContentLayer)"></onfocused>
      <onfocused expr="Show(Net_ContentLayer)"></onfocused>
      <onunfocused expr="Exit(Net_ContentLayer)"></onunfocused>

      <transition event="auth.success"    expr="SendEvent('loadStart')"></transition>
      <transition event="@UI.ACCEPT*RELEASED" target="PlaySound('HUD_MENU_SELECT_MASTER')"></transition>

      <UIButton desc="mp_fe_play_online_tab"  target="NetConf_PlayPublic" consume="false">
        <onfocused expr="Select(NetContent_Public)"></onfocused>
        <transition event="retry_action">
          <action expr="goto(NetConf_PlayPublic)"></action>
          <action expr="NetMachine.Authenticate('Online Multiplayer')"></action>
        </transition>
      </UIButton>

      <UIButton desc="mp_fe_play_private_tab" target="NetConf_PlayPrivate" consume="false">
        <onfocused expr="Select(NetContent_Private)"></onfocused>
        <transition event="retry_action">
          <action expr="goto(NetConf_PlayPrivate)"></action>
          <action expr="NetMachine.Authenticate('Online Multiplayer')"></action>
        </transition>
      </UIButton>

      <ifdef expr="PSN">
        <data name="messages" expr="NetOffTab_Inbox"></data>
        <transition event="PM.UnfocusInbox">
          <action expr="Unfocus(Net_ContentLayer)"></action>
          <action expr="Enter(NetOfflineTabs)"></action>
        </transition>
        <UILabel  id="NetOffTab_Inbox"   desc="net_invites">
          <onfocused expr="Select(OnlineInbox)"></onfocused>
          <transition event="@UI.ACCEPT*RELEASED">
            <action expr="PlaySound('HUD_MENU_SELECT_MASTER')"></action>
            <action expr="Unfocus(NetOfflineTabs)"></action>
            <action expr="Enter(Net_ContentLayer)"></action>
          </transition>
        </UILabel>
      </ifdef>

      <UILabel desc="mp_fe_play_lan_tab"     target="NetConf_PlayLAN" consume="false">
        <onfocused expr="Select(NetContent_LAN)"></onfocused>
      </UILabel>

      <ifdef expr="XENON">
        <onfocused expr="NetMachine.SendPresenceEvent()"></onfocused>
        <transition event="net.IsSignedOffline"                 target="Exclude(NetOfflineTab_Party)"></transition>
        <transition event="net.IsSignedOnline"                  target="Include(NetOfflineTab_Party)"></transition>
        <transition event="net.signedOffline" consume="false"   target="Exclude(NetOfflineTab_Party)"></transition>
        <transition event="net.signedOnline"  consume="false"   target="Include(NetOfflineTab_Party)"></transition>
        <UILabel id="NetOfflineTab_Party" desc="mp_fe_partyui_tab"  target="NetScene.ShowCommunityUI()" consume="false">
          <onfocused expr="Select(NetContent_Party)"></onfocused>
        </UILabel>
      </ifdef>
    </NetMenu>

    <!-- ======================================= CONTENT PANEL ==================================================== -->

    <include src="Net/OfflineMenu.sc"></include>
    <include src="Net_Profile.sc.xml"></include>

    <!-- ============================================= PROMPTS ==================================================== -->

    <onfocused expr="Enter(NetLayer_Prompts)"></onfocused>
    <onunfocused expr="Exit(NetLayer_Prompts)"></onunfocused>
    <UILayer id="NetLayer_Prompts">      
      <transition event="@UI.CANCEL*RELEASED">
        <action	expr="PlaySound('HUD_MENU_BACK_MASTER')"></action>
        <action expr="Exit(NetworkingLayerOffline)"></action>
        <action expr="focus(PauseMenu)"></action>
      </transition>
      
      <UIPromptStrip id="NetPrompts_MainMenu">
          <UIButton text="Common_Select" icon="{@UI.ACCEPT}"></UIButton>
          <UIButton text="Common_Back" icon="{@UI.CANCEL}"></UIButton>
        <UIButton icon="{@UI.NAVIGATE_UP}{@UI.NAVIGATE_DOWN}" text="Common_Scroll"></UIButton>
      </UIPromptStrip>

      <UIPromptStrip id="NetPrompts_Inbox" flashObject="_global.prompt">
        <UIButton id="NetInbox_AcceptInvite" icon="{@UI.ACCEPT}" text="mp_gamer_joingame">
          <transition event="@UI.ACCEPT*RELEASED">
            <action expr="PlaySound('HUD_MENU_SELECT_MASTER')"></action>
            <action expr="Enter(InboxInvite_Validating)"></action>
          </transition>
        </UIButton>
        <UIButton icon="{@UI.CANCEL}" text="Common_Back">
          <transition event="@UI.CANCEL*RELEASED">
            <action	expr="PlaySound('HUD_MENU_BACK_MASTER')"></action>
            <action expr="SendEvent('PM.UnfocusInbox')"></action>
          </transition>
        </UIButton>

      </UIPromptStrip>
    </UILayer>
  </UILayer>

  <!-- ============================================= DIALOGS ==================================================== -->

  <UIMessageBox id="NetAlert_BlockedMP" alert="true">
    <data name="description"  expr="NetBlockAlert_PriveledgesMP"></data>      
    <UIPromptStrip>
      <ifdef expr="PSN">
        <UIButton text="Common_Ok"            icon="{@UI.ACCEPT}" e_action_released="Exit(NetAlert_BlockedMP)"      ></UIButton>
      </ifdef>
      <ifdef expr="XENON">
        <UIButton text="Common_ChangeProfile" icon="{@UI.ACCEPT}" e_action_released="NetMachine.ShowSignInUI(true)" ></UIButton>
        <UIButton text="Common_Cancel"        icon="{@UI.CANCEL}" e_cancel_released="Exit(NetAlert_BlockedMP)"      ></UIButton>
      </ifdef>

    </UIPromptStrip>
  </UIMessageBox>

  <UIMessageBox id="NetAlert_NotOnline">
    <data name="alert"></data>
    <data name="description" expr="NetBlockAlert_NotOnline"></data>
    <ifdef expr="PSN">
      <onshow expr="NetMachine.ShowSignInUI(true)"></onshow>
      <transition event="net.signedOnline">
        <action expr="Exit(NetAlert_NotOnline)"></action>
        <action expr="SendEvent('retry_action')"></action>
      </transition>
    </ifdef>
    <transition event="@UI.ACCEPT*RELEASED" target="Exit(NetAlert_NotOnline)"></transition>
    <UIPromptStrip>
      <UIButton text="Common_Ok" icon="{@UI.ACCEPT}"></UIButton>
    </UIPromptStrip>
  </UIMessageBox>

  <UIMessageBox id="NetAlert_NotSignedIn">
    <data name="alert"></data>
    <data name="description" expr="NetBlockAlert_NotSignedIn"></data>
    <transition event="@UI.ACCEPT*RELEASED" target="Exit(NetAlert_NotSignedIn)"></transition>
    <UIPromptStrip>
      <UIButton text="Common_Ok" icon="{@UI.ACCEPT}"></UIButton>
    </UIPromptStrip>
  </UIMessageBox>

  <UIMessageBox id="NetAlert_NotSignedInSysLink">
    <data name="alert"></data>
    <data name="description" expr="NetBlockAlert_NotSignedInSysLink"></data>
    <transition event="@UI.ACCEPT*RELEASED" target="Exit(NetAlert_NotSignedInSysLink)"></transition>
    <UIPromptStrip>
      <UIButton text="Common_Ok" icon="{@UI.ACCEPT}"></UIButton>
    </UIPromptStrip>
  </UIMessageBox>

  <UIMessageBox id="NetAlert_NoCable">
    <data name="alert"></data>
    <data name="description" expr="NetBlockAlert_NoCable"></data>
    <data name="priority" expr="1"></data>
    <ifdef expr="PSN">
      <onshow expr="NetMachine.ShowSignInUI(true)"></onshow>
      <transition event="net.signedOnline">
        <action expr="Exit(NetAlert_NoCable)"></action>
        <action expr="SendEvent('retry_action')"></action>
      </transition>
    </ifdef>
    <transition event="@UI.ACCEPT*RELEASED" target="Exit(NetAlert_NoCable)"></transition>
    <UIPromptStrip>
      <UIButton text="Common_Ok" icon="{@UI.ACCEPT}"></UIButton>
    </UIPromptStrip>
  </UIMessageBox>

  <UIMessageBox id="NetConf_PlayPublic">
    <include src="net/PlayMpConf.sc" arg="NetConf_PlayPublic,'Online Multiplayer','Public'"></include>
  </UIMessageBox>

  <UIMessageBox id="NetConf_PlayPrivate">
    <include src="net/PlayMpConf.sc" arg="NetConf_PlayPrivate,'Online Multiplayer','Private'"></include>
  </UIMessageBox>

  <UIMessageBox id="NetConf_PlayLAN">
    <data name="alert"></data>
    <data name="priority"></data>
    <data name="description" expr="mp_newgame_conf"></data>

    <onshow expr="NetMachine.ResetNewGameWarning('LAN')"></onshow>
    <onshow expr="NetMachine.SetMultiplayerModeToLaunch('LAN')"></onshow>
    <onshow expr="NetMachine.SetFreeRoamMode('Normal')"></onshow>

    <transition event="auth.fail_NotSignedIn">
      <action expr="Exit(NetConf_PlayLAN)"></action>
      <action expr="SendEvent('codered.LANBootstrap')"></action>
    </transition>
    <transition event="auth.fail_NoCable">
      <action expr="Exit(NetConf_PlayLAN)"></action>
      <action expr="SendEvent('codered.LANBootstrap')"></action>
    </transition>
    <transition event="auth.fail_NotOnline">
      <action expr="Exit(NetConf_PlayLAN)"></action>
      <action expr="SendEvent('codered.LANBootstrap')"></action>
    </transition>
    <transition event="auth.fail_Privileges">
      <action expr="Exit(NetConf_PlayLAN)"></action>
      <action expr="SendEvent('codered.LANBootstrap')"></action>
    </transition>
    <transition event="auth.success_NoComm">
      <action expr="Exit(NetConf_PlayLAN)"></action>
      <action expr="SendEvent('codered.LANBootstrap')"></action>
    </transition>

    <transition event="auth.success">
      <action expr="Exit(NetConf_PlayLAN)"></action>
      <action expr="SendEvent('codered.LANBootstrap')"></action>
    </transition>

    <UIPromptStrip>
      <UIButton text="Common_Yes" icon="action" target="NetMachine.Authenticate('LAN Multiplayer')"></UIButton>
      <UIButton text="Common_No" icon="cancel" e_cancel_released="Exit(NetConf_PlayLAN)"></UIButton>
    </UIPromptStrip>
  </UIMessageBox>

  
  
</scxml>
