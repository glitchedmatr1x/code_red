// Animal TR programs and rules live in a separate file now. /FF
#include "animals.tr"

// Audio (speech "feedback") stuff has been split off. /FF
#include "audio.tr"


// Main human program
program Main
{
	TRUE	->	Main0, PerformExternalGoals, UpdateHostility;
}


program Main0
{
	// Perform highest priority tasks first, if any.
	ExternalPriorityHighest && CanPerformTask		->	PerformTask;

	// If we're currently riding on a horse we're not allowed to be on, dismount whenever possible.
	// Note that the target of TASK_MOUNT is excepted.
	RidingOn(x) && !AllowedToRide(x) && CanRideDismount && !ObjectClassObjectiveMount(x)				-> RideDismount;

	// Retreat from nearby explosive projectiles (dynamite), if we've seen it recently and we didn't throw it.
	// TODO: Do this for our own projectiles too, if they aren't moving. In that case we probably screwed up - run like hell!
	// TODO: Maybe try to find a better place for this. I tried to put it inside the Survival program, but
	// I think some action arbitration issues made that not work very well.
	// TODO: Change the distance involved here to match the expected explosion radius.
	ObjectClassProjectileExplosive(x) && !ObjectClassProjectileLaunchedByMe(x) && WasVisibleVeryRecently(x) && SpatialLastObservedDistanceClose(x) && CanMoveRetreatFrom(x) 	->	MoveRetreatFrom(x):(SpeechEvent("FleeingDynamite", x)), LookAtIfPossible(x), SpeedSprint;

	// Explosive projectiles that we've seen recently that are not covered by the above,
	// sit around and look at until it explodes, while shooting at the enemies if possible.
	// TODO: Try to find a better place for the rule.
	ObjectClassProjectileExplosive(x) && WasVisibleVeryRecently(x) ->	PostureCrouch, LookAtIfPossible(x), Stay, AutonomousFire;

	TRUE		->	Main1, AudioTestSpeechEvents, Survival WITH 8.0;
}


program Main1
{
	// This can be enabled for more strictly controlled squad formations.
	//InSquad								->	SquadMain;

	// If already in a conversation, continue it.
	CanConverseContinue(x)				->	ConverseContinue(x);
	
	// Continue with combat and lower priority stuff while simultaneously
	// run programs for taking cover if threatened.
	// Note: I added the currently commented out WITH 2.0 here - I think it's suboptimal
	// to execute ResolveConveyancePrefs in parallel without increasing its strength, since
	// if the actor is already executing for example Stay with strength 1.1, it wouldn't switch
	// to get on a horse. I'm leaving it out for now, because it's milestone week and no
	// specific bugs have been reported about this. /FF
	
	NOT Riding							->	Main2, SeekCoverFromEnemies, GetBehindCoverIfUnderFire, GetToCoverIfThreatened, PerformSquadActions, ResolveConveyancePrefs /* WITH 2.0 */;

	// If we're riding, we can't do cover stuff.
	TRUE								->	Main2, PerformSquadActions, ResolveConveyancePrefs /* WITH 2.0 */;
}


program PerformSquadActions
{
	!InSquad						->	NIL;
	
	// TODO:  test this thoroughly!  Get on or off of a nearby horse if our squad leader does.
	// Note: I added PrefersWalking/PrefersRiding checks here, so they take precedence over the
	// autonomous stuff now.
	!Riding && !PrefersWalking && SquadLeader(x) && Riding(x) && CanMountNearbyHorse		->	MountNearbyHorse, SpeedJog;
	Riding && !PrefersRiding && SquadLeader(x) && !Riding(x) && CanRideDismount				->  RideDismount;

	TRUE							->	StayNearSquad;
}

rules EnableBehaviors
{
	// CodeRED Apocalypse: every human AI gets suspicion, help, identification, investigation, search, and combat pressure.

	HasSomethingToGuard				->	Guard;
	HasPatrolPath					->	Guard;

	// Enable this for everybody.
	TRUE							->	EnableSurvival;

	// For now, enable everybody to engage enemies. TODO: This needs
	// some work, we may want characters to attack enemies if they have
	// the chance, or to simply defend themselves if attacked, but without
	// trying to actively hunt down enemies.
	TRUE							->	EnableCombatEngageEnemies;

	// For now, let's not bother about suspicious persons. That was more
	// of a thing in Agent and has the risk of just making it harder
	// for designers to get scripting to work.
	FALSE							->	EnableDealWithSuspiciousPersons;
//	Guard							->	EnableDealWithSuspiciousPersons;

	Guard							->	EnableHelpOthers;
	Guard							->	EnableIdentification;
	Guard							->	EnableInvestigateAll;
	Guard							->	EnableSearchUndirected;
}


// This is the lower priority part of Main, which is carried out in parallel to
// programs that make the actor take cover if threatened.
program Main2
{
	ExternalPriorityCombat && CanPerformTask						->	PerformTask;

	EnableCombatEngageEnemies && CanCombatEngageEnemies				->	CombatEngageEnemies;

	TRUE															->	GuardRoutine WITH 8.0;
//	TRUE															->	GuardRoutine_Old;
}


// Survival goal, making the actor run away and diving away from danger.
// Intended to be used in parallel with other programs.
program Survival
{
	!EnableSurvival						->	NIL;

	// Note: Enemy(x) used to be included in CanRetreatFrom(x), but now
	// CanMoveRetreatFrom(x) is defined in code and is directly tied to
	// what the elementary action MoveRetreatFrom(x) can handle.
	ShouldRetreat AND CanMoveRetreatFrom(x) AND Enemy(x)	
		->	MoveRetreatFrom(x):(SpeechEvent("Retreating"), SpeechEvent("DisallowShootAndFace")), 
			DodgeWhileRetreatingFrom(x),			
			SpeedSprint;

	// This rule makes actors dive if they hear a nearby projectile impact but have
	// not been hit recently. We should consider the following improvements:
	// - Make it happen only if multiple projectile impacts are heard.
	// - Reduce the distance.
	// The VeryCloseToEnemies part is there to prevent actors from diving when close
	// to an enemy that other allies are likely to fire at. This is a bit of a hack
	// but seems to work alright in practice.
	// TODO: Think about if the InSquad predicate should be here or not.
// Disabled for now, it really doesn't work well in most situations. /FF
//	!InSquad && NewProjectileImpact(x) && !VeryCloseToEnemies && !ActivityDoveRecently && !DamagedRecently && SpatialDistanceVeryClose(x)	->	DiveAwayFrom(x)	WITH 0.6;	// ?
}


// Undirected searches, such as a guard would use if he knows there may be
// an enemy around but has no idea where he is.
// Intended to be used in parallel with other programs.
program SearchUndirected
{
	// Probably temporary. For now this prevents posse members from
	// searching the area themselves.
	!EnableSearchUndirected									->	NIL;

	// Start an alerted search.
	CanAlertedSearch && ShouldAlertedSearch					->	AlertedSearch;

	// Start an unalerted search.
	CanUnalertedSearch && ShouldUnalertedSearch				->	UnalertedSearch;
}


// Program for investigating dead bodies, explosions, and gunshots.
// Intended to be used in parallel with other programs.
program InvestigateAll
{
	!EnableInvestigateAll		->	NIL;

	TRUE						->	InvestigateBodies, InvestigateExplosions, InvestigateGunshots;
}


// Program for investigating dead bodies.
// Intended to be used in parallel with other programs.
program InvestigateBodies
{
	// If we encounter a corpse that died recently (but we didn't see it), go check out the body.
	CanInvestigateBody(x) AND ShouldInvestigateBody(x)	->	InvestigateBody(x);
}


// Program for investigating explosions.
// Intended to be used in parallel with other programs.
program InvestigateExplosions
{
	// If we heard an explosion and we're looking at the location where we heard it,
	// but we are still investigating it, then just keep looking.  No hurry!
	RecentExplosion(x) AND KnowsWhereIs(x) AND Investigating(x)	->  MaintainLineOfSight(x), SpeedWalk;

	// If we heard an explosion and we're not finished investigating it, 
	// hurry over to look at the location where we heard the sound.
	RecentExplosion(x) AND NOT Investigated(x)				->  ObserveLastKnownPosition(x), SpeedSprint;
}


// Program for investigating gunshots.
// Intended to be used in parallel with other programs.
program InvestigateGunshots
{
	// If we hear someone unknown to us (or an enemy that we lost track of) firing a weapon,
	// try going to the location where we heard the weapon.
	UnknownWeaponFired(x) OR HiddenEnemyWeaponFired(x)	
		AND CanObserveLastKnownPosition(x)					->	ObserveLastKnownPosition(x), SpeedJog;
}


debuggroup Help
{
	filter ScreamedSomewhatRecently(x), predicate BecameVisibleVeryRecently(x),		label "BecameVisibleVeryRecently $x";
	filter ScreamedSomewhatRecently(x), predicate WasVisibleRecently(x),			label "WasVisibleRecently $x";
	filter ScreamedSomewhatRecently(x), predicate MayNeedHelp(x),					label "MayNeedHelp $x";
	filter ScreamedSomewhatRecently(x), predicate ScreamedSinceLastClearlyVisible(x),label "ScreamedSinceLastClearlyVisible $x";
	filter ScreamedSomewhatRecently(x), predicate Ally(x),							label "Ally $x";
}


rules Preconditions_HelpOthers
{
	// Precondition for the Help(x) program.
	(WasVisibleJustNow(x) && SpatialDistanceVeryClose(x)) || CanFindAndMoveTowards(x)		->	CanHelp(x);
}

rules Rules_HelpOthers
{
	// Somebody that's screaming and that we haven't looked for after that may need help.
	ScreamedRecently(x) && ScreamedSinceLastClearlyVisible(x)								->	MayNeedHelp(x);

	// For now, only help allies if they need it. In most cases SpatialDistanceClose(x)
	// probably doesn't make a difference because our current scream range is smaller than
	// that, but it would prevent actors from starting to help somebody if they are likely
	// to not get there before they would decide to stop going there (because ScreamedRecently
	// would turn to false).
	Ally(x) && SpatialDistanceClose(x)														->	ShouldHelpIfNeeded(x);
}


// Program for paying attention to nearby allies that scream for help.
// Intended to be used in parallel with other programs.
program HelpOthers
{
	!EnableHelpOthers										->	NIL;

	MayNeedHelp(x) && ShouldHelpIfNeeded(x) && CanHelp(x)	->	Help(x);
}


// "Help" actor x by going towards him and make sure that he's safe. Note that
// other programs will need to intervene with any threats to x, this program
// just makes sure that we get there and look at him for a while.
// Precondition:	CanHelp(x)
// Goal:			LookedFor(x)
program Help(x)
{
	// If close and x is in view, stand still and look at him. The perception
	// system should make LookedFor(x) go true after a while.
	WasVisibleJustNow(x) && SpatialDistanceVeryClose(x) && CanLookAt(x)					->	LookAt(x), Stay;
	WasVisibleJustNow(x) && SpatialDistanceVeryClose(x)									->	Stay;

	// If we're not close enough or can't see x, run towards him or
	// search for him.
	TRUE																->	FindAndMoveTowards(x), SpeedSprint;
}


// Program for responding to the player trying to initiate a conversation.
// Intended to be used in parallel with other programs.
program RespondToConversations
{
	InitiatingConversation(x) && CanConverseRespond(x)	->	ConverseRespond(x);
}


// Program for identifying unknown persons.
// Intended to be used in parallel with other programs.
program Identification
{
	!EnableIdentification											->	NIL;

	// Identify unknowns with haste if enemies are known or believed to be present.
	EnemiesAreAround && !Identified(x) && CanIdentify(x)	->	Identify(x), SpeedJog;

	// If there are unknown persons around, identify them. This isn't done if
	// we have been assigned a post to stand guard at.
	!Identified(x) && CanIdentify(x) && !HasSomethingToGuard		->	Identify(x);

	// If we have something to guard, the presence of this rules makes
	// the actor at least look towards unidentified persons even if he
	// won't leave his post.
	PossibleEnemy(x) && SpatialDistanceClose(x) && CanLookAt(x)		->	LookAt(x);
}

//-----------------------------------------------------------------------------
// Behavior for guards who are attempting to detect an enemy presence.
program GuardRoutine
{
	// Invoke a bunch of goals in parallel. TODO: See if the weights can be
	// adjusted to lie in a smaller range.
	TRUE	->
			InvestigateAll,
			HelpOthers,
			Identification WITH 0.75,
			SearchUndirected WITH 0.5,
			RespondToConversations WITH 0.5,
			DealWithSuspiciousPersons WITH 0.25,
			Unalerted WITH 0.125
			;
}

//-----------------------------------------------------------------------------

// PURPOSE:	Act in a hostile fashion against target x.
program BeHostileAgainst(x)
{
	// Execute the sub-program, remember that we are in this "hostile attention"
	// state, and prepare to attack after a time delay. /FF
	TRUE	->	BeHostileAgainstInternal(x), SpeechEvent("HostileAttention"), PrepareForActivity(3);
}


// PURPOSE:	Used internally by BeHostileAgainst(x), containing most of the logic for
//			the "hostile state" behavior.
program BeHostileAgainstInternal(x)
{
	// If we can and should fight, do so and remember that we are fighting. /FF
	HostileFight(x) && CanCombatFight(x)														->	CombatFight(x), SpeechEvent("HostileFight");

	// As a fallback, if we can't fight, shoot instead. The primary need for this is
	// to deal with the case when x is riding. First, draw our weapon if we haven't already,
	// then use the CombatShootNoCover(x) program. /FF
	HostileFight(x) && !CombatRangeWeaponReadied && CanCombatReadyRangeWeapon					->	CombatReadyRangeWeapon, LookAtIfPossible(x);
	HostileFight(x) && CanCombatShootNoCover(x)													->	CombatShootNoCover(x), SpeechEvent("HostileFight");

	// If the target has his weapon drawn, and we can draw ours, do so. /FF
	CombatRangeWeaponDrawn(x) && !CombatRangeWeaponReadied && CanCombatReadyRangeWeapon			->	CombatReadyRangeWeapon, LookAtIfPossible(x);

	// Look at the target. /FF
	CanLookAt(x)																				->	LookAt(x);
}


// PURPOSE:	The only reason for this program is that I needed a way to cancel a
//			planned activity when not in the "hostile attention state".
// TODO:	Try to remove, I don't like how this works. /FF
program UpdateHostility
{
	// TODO: See if there is a better way to make sure we've got a specific activity planned,
	// rather than this ugly thing which cancels and plans the activity all the time. /FF
	// TODO: Make the time delay here data driven. /FF
	!EventActive("HostileAttention")		->	CancelPlannedActivity(3), PlanActivity(3, 15.0, 15.0);
}


rules Rules_Hostility
{
	// PURPOSE:	Check if we should be in a hostile state towards x. EventActive() is used
	//			for hysteresis, which I don't really like. /FF
	Hostile(x) && ((CombatClassCloserThanHostileAttentionDistanceInner(x) && !EventActive("HostileAttention")) ||
		(CombatClassCloserThanHostileAttentionDistanceOuter(x) && EventActive("HostileAttention"))) && PositionKnownRecently(x)			->	HostileAttention(x);

	// PURPOSE:	Check if we should be attacking now during our hostile state. This will happen
	//			after a certain amount of time has expired, or if x gets too close. It will also
	//			continue if it's already in progress (until a higher level distance threshold is reached). /FF
	(CombatClassCloserThanHostileAttackDistance(x) || ActivityReadyToPerform(3) || EventActive("HostileFight"))							->	HostileFight(x);

	// PURPOSE:	Precondition for the BeHostileAgainst(x) program. /FF
	// NOTES:	For now, we don't use this for actors on horseback, as it's not nearly clear enough to the player
	//			that they are being hostile.
	HostileAttention(x) && (
			CanLookAt(x) ||
			(CanCombatFight(x) && HostileFight(x)) ||
			(HostileFight(x) && !CombatRangeWeaponReadied && CanCombatReadyRangeWeapon) ||
			(HostileFight(x) && CanCombatShootNoCover(x))
		) && !Riding											->	CanBeHostileAgainst(x);
}


debuggroup Hostilility
{
	filter Hostile(x), predicate CombatClassCloserThanHostileAttentionDistanceInner(x), label "Attention Distance Inner $x";
	filter Hostile(x), predicate CombatClassCloserThanHostileAttentionDistanceOuter(x), label "Attention Distance Outer $x";
	filter Hostile(x), predicate CombatClassCloserThanHostileAttentionDistanceOuter(x), label "Fight Distance $x";
	filter Hostile(x), predicate HostileAttention(x), label "Attention $x";
	filter Hostile(x), predicate HostileFight(x), label "Fight $x";
}

//-----------------------------------------------------------------------------

// Standard operating procedure for guards who are not currently aware of an enemy presence.
// Goal:			<none>
// Precondition:	NOT Enemy(x)		// We have defeated (or forgotten?) all enemies.

program Unalerted
{
	InSquad												->	SquadUnalerted;

	// Act in a hostile fashion against x, if appropriate. The SpatialDistanceVeryClose(x)
	// here is only to add a preference towards nearby targets, and isn't critical. /FF
	Hostile(x) && CanBeHostileAgainst(x) && SpatialDistanceVeryClose(x)	->	BeHostileAgainst(x);
	Hostile(x) && CanBeHostileAgainst(x)								->	BeHostileAgainst(x);

	// This makes ambient civilians and other non-guard actors
	// retreat from dangerous objects they have no reason to get
	// involved with, for example some guy firing his gun.
	!Guard && CivilianDanger(x)							->	StayAwayFromDanger(x);

	// This makes civilians run away if they see a creature get hit
	// by a projectile. This is a bit odd in that they treat the creature
	// that got hit as a danger, but that makes some sense if there is no
	// additional knowledge of the shooter's position - if they saw the shooter
	// shoot or if they heard the gunshot, the rule right above this one
	// would fire and override this one, so we would stay away from the
	// shooter, not the target.
	!Guard && HitByProjectileRecently(x) && ObjectClassCreature(x) && SpatialDistanceClose(x)				->	StayAwayFromDanger(x);

	// Perform unalerted task, staying on the lookout for hotspots to use.
	ExternalPriorityUnalerted && CanPerformTask				->	PerformTask;

	// TEST HACK:  if the player bumps us, flee!
	((EventActive("PlayerBump", x) AND SpatialDistanceVeryClose(x)) OR
		(BumpedIntoMeJustNow(x) AND Player(x))) 
		AND CanMoveRetreatFrom(x)										->	MoveRetreatFrom(x):(SpeechEvent("PlayerBump", x)), SpeedWalk;

	// If already in a bump chat, continue it until totally satisfied.
	BumpTalkingWith(x) AND ShouldContinueBumpTalk AND CanBumpTalkWith(x) 		->	BumpTalkWith(x);

	// If we bump into something near someone, start chatting with them.
	BumpedIntoMeJustNow(x) AND 
		ShouldStartBumpTalk AND CanBumpTalkWith(x) 				->	BumpTalkWith(x);

	// If we bump into something, start looking for something behind us.
	//CollidedJustNow
	//	AND NOT NearGoalHotspot(3.0)
	//	AND NOT SpatialDirectionAheadOfMe(x) 
	//	AND Close(x)
	//	AND CanMoveTowards(x)			->	WallBump, MoveTowards(x):(SpeechEvent("BumpRecovery", x));
		
	// If we're recovering from a bump, keep moving until we're close to the thing we picked.
	//EventActive("BumpRecovery", x)
	//	AND NOT NearGoalHotspot(3.0)
	//	AND NOT At(x)
	//	AND CanMoveTowards(x)			->	WallBump, MoveTowards(x):(SpeechEvent("BumpRecovery", x));

	// If already in a social chat, continue it until reasonably satisfied.
	SocialTalkingWith(x) AND CanSocialTalkWith(x) AND ShouldContinueSocialTalk		->	SocialTalkWith(x);

	// Keep idling if we're in the middle of idling; start idling if we haven't done so in a while.
	// HACK: Future Activity #0 = idle
	!ActivityFinishedIdlingRecently AND ReadyToIdle	->	Idle, PlanActivity(0, 15.0, 17.0);

	// If we've found a hotspot to use, move to it and use it.
	CanHotspotsMoveToAndUse									->	HotspotsMoveToAndUse, HotspotSeekToFulfillMotives;

	// "Speak with" a fellow character.
	ShouldStartSocialTalk AND CanSocialTalkWith(x)			->	SocialTalkWith(x);

	// Move to a fellow character, to have a social chat with them.
	ShouldStartSocialTalk AND CanMoveToAndSocialTalkWith(x)	->	MoveTowards(x), PrepareForActivity(0), HotspotSeekToFulfillMotives;	//, LookIntentlyAtIfPossible(x);

	//Execute lowest priority scripting commands (mostly intended to be used for the ambient ped default behavior).
	ExternalPriorityDefaultBehavior && CanPerformTask		->	PerformTask, HotspotSeekToFulfillMotives;

	// The default action:  don't move, do nothing, except seeking
	// hotspots in the background.
	TRUE													->	LookAround, Stay, HotspotSeekToFulfillMotives;
}

debuggroup Idle
{
	filter TRUE,			predicate ActivityIdledJustNow,				label "ActivityIdledJustNow";
	filter TRUE,			predicate ActivityStartedIdlingRecently,	label "ActivityStartedIdlingRecently";
	filter TRUE,			predicate ActivityFinishedIdlingRecently,	label "ActivityFinishedIdlingRecently";
	filter TRUE,			predicate ReadyToIdle,						label "ReadyToIdle";
}


debuggroup Bump
{
	filter TRUE,							predicate CollidedVeryRecently,				label "CollidedVeryRecently";
	filter TRUE,							predicate CollidedJustNow,					label "CollidedJustNow";
	filter TRUE,							predicate ShouldStartBumpTalk,				label "ShouldStartBumpTalk";
	filter TRUE,							predicate ShouldContinueBumpTalk,			label "ShouldContinueBumpTalk";
	filter CanBumpTalkWith(x),				predicate CanBumpTalkWith(x),				label "CanBumpTalkWith $x";
	filter EventActive("BumpRecovery", x),	predicate EventActive("BumpRecovery", x),	label "BumpRecovery $x";
	filter EventActive("PlayerBump", x),	predicate EventActive("PlayerBump", x),		label "PlayerBump $x";
}

rules SocialTalkRules
{
	(MotiveSatisfactionLessThan("Social", 50.0) AND LowestMotive("Social")) OR
			MotiveSatisfactionLessThan("Social", 20.0)			->	ShouldStartSocialTalk;
			
	MotiveSatisfactionLessThan("Social", 60.0)					->	ShouldContinueSocialTalk;
	
	ObjectClassHuman(x) AND SpatialDistanceClose(x)	
			AND CanMoveTowards(x) AND NOT Player(x)				->	CanMoveToAndSocialTalkWith(x);
			
	ObjectClassHuman(x) AND SpatialDistanceExtremelyClose(x)	
			AND NOT Player(x)									->	CanSocialTalkWith(x);
			
	EventActive("SocialTalk", x)								->	SocialTalkingWith(x);
}		

rules BumpTalkRules
{
	MotiveSatisfactionLessThan("Social", 80.0)					->	ShouldStartBumpTalk;

	MotiveSatisfactionLessThan("Social", 90.0)					->	ShouldContinueBumpTalk;
			
	ObjectClassHuman(x) AND SpatialDistanceExtremelyClose(x)
			/*AND NOT Player(x)*/								->	CanBumpTalkWith(x);
			
	EventActive("BumpTalk", x)									->	BumpTalkingWith(x);
}

debuggroup SocialTalk
{
	filter TRUE,				predicate ShouldStartSocialTalk,			label "ShouldStartSocialTalk";
	filter TRUE,				predicate ShouldContinueSocialTalk,			label "ShouldStartSocialTalk";
	filter ObjectClassHuman(x),	predicate CanMoveToAndSocialTalkWith(x),	label "CanMoveToAndSocialTalkWith $x";
}


program SocialTalkWith(x)
{
	SpatialLastObservedMeAheadOfObject(x)	-> 
		Stay:(SpeechEvent("SocialTalk", x)), Face(x), TalkAnim, FulfillMotive("Social", 5.0);
	
	TRUE	->
		Stay:(SpeechEvent("SocialTalk", x)), Face(x);
}


program BumpTalkWith(x)
{
	TRUE	-> 
		Stay:(SpeechEvent("BumpTalk", x)), Face(x), TalkAnim, FulfillMotive("Social", 5.0);
}


// This program moves to the "current" hotspot and uses it. It does not care
// about how this current hotspot was found, and doesn't by itself look for
// any hotspots.
// Precondition:	CanHotspotsMoveToAndUse
program HotspotsMoveToAndUse
{
	CanHotspotUse					->	HotspotUse;
	TRUE /*CanHotspotMoveTo*/		->	HotspotMoveTo;
}


debuggroup PreconditionsPlayerOnly
{
	filter Player(x),	predicate BaseCanMoveTowards(x),			label "BaseCanMoveTowards $x";
	filter Player(x),	predicate CanConverseContinue(x),			label "CanConverseContinue $x";
	filter Player(x),	predicate CanConverseRespond(x),			label "CanConverseRespond $x";
	filter Player(x),	predicate CanFind(x),						label "CanFind $x";
	filter Player(x),	predicate CanFindAndMoveTowards(x),			label "CanFindAndMoveTowards $x";
	filter Player(x),	predicate CanMoveTowards(x),				label "CanMoveTowards $x";
	filter Player(x),	predicate CanMoveTowardsWithoutSearch(x),	label "CanMoveTowardsWithoutSearch $x";
	filter Player(x),	predicate CanObserveLastKnownPosition(x),	label "CanObserveLastKnownPosition $x";
}

// This ruleset contains preconditions for various actions. The precondition
// for action X(<args) is named CanX(<args>), and the user of any action
// is responsible for checking that the precondition is fulfilled. Note that
// the precondition is different from the goal - it should be valid to use
// an action even if it's goal is already fulfilled.
rules Preconditions
{
	// These are all elementary actions (defined in code), and the preconditions
	// for those should probably be defined in code as well.
	TRUE													->	CanConverseRespond(x);// Elementary action.
	InConversationWith(x)									->	CanConverseContinue(x);// Elementary action.
	BaseCanMoveTowards(x) && !CannotMoveTowards(x)			->	CanMoveTowards(x);	// Elementary action.

	// These are preconditions for TR programs.
	(!KnowsWhereIs(x) && CanFind(x)) OR 
		(KnowsWhereIs(x) && CanMoveTowards(x))				->	CanFindAndMoveTowards(x);

	(KnowsWhereIs(x) AND At(x)) OR 
		(CanMoveTowards(x) AND CanObserveLastKnownPosition(x) 
			AND NOT NotAtLastKnownPosition(x))				->	CanMoveTowardsWithoutSearch(x);

	TRUE													->	CanFind(x);

	// Note: I disabled the CanMoveTowards(x) part here. The TR program
	// looks like it's been specifically designed to handle the
	// !CanMoveTowards(x) case, and it improves the behavior for AI actors
	// riding shotgun on stagecoaches. /FF
	//LastKnownPositionExists(x) AND CanMoveTowards(x)		->	CanObserveLastKnownPosition(x);
	LastKnownPositionExists(x)								->	CanObserveLastKnownPosition(x);

	(CombatAtCover && (CombatAtCoverGood || (!CanCombatMoveToCover && !InjuredWhileAtThisNoGoodCover))) || CanCombatMoveToCover		->	CanGetToCover;
	CombatAtCover || CanGetToCover																									->	CanGetBehindCover;

	CanHotspotUse || CanHotspotMoveTo						->	CanHotspotsMoveToAndUse;
}

// Rules about who we consider to be our friends and foes.  The elementary predicates 
// BaseAlly, BaseEnemy and BaseNeutral form our basis for this, but we 
// also add further rules, like treating unidentified characters as possible enemies,
// or attacking neutrals if our allies are attacking them.
rules AlliesAndEnemies
{
	// Code RED Pass2 apocalypse escalation: hostiles and criminals are treated as full enemies.
	Alive(x) && BaseHostile(x)									->	TreatAsEnemy(x);
	Alive(x) && Criminal(x)									->	TreatAsEnemy(x);
	IsLawEnforcement && Alive(x) && (BaseHostile(x) || Criminal(x) || Hostile(x))		->	TreatAsEnemy(x);

	// I added this to replace some logic in the code, so that TR programs can now
	// start treating hostile and friendly actors differently from neutral. I simply
	// replaced all old usage of BaseNeutral(x) with BaseSomewhatNeutral(x). It's
	// quite possible that this rule will go away, but I needed it temporarily
	// to safely preserve existing behavior. /FF
	BaseNeutral(x) || BaseHostile(x) || BaseFriendly(x)		->	BaseSomewhatNeutral(x);

	BaseHostile(x) && Alive(x)								->	Hostile(x);

	// Ally(a) && Attacking(a, x)							->	AttackedByMyAllies(x);
	FALSE													->	AttackedByMyAllies(x);
	Alive(x) AND BaseAlly(x)								->	Ally(x);
	NOT Alive(x) AND BaseAlly(x)							->	DeadAlly(x);
	Alive(x) AND (BaseEnemy(x) OR 
		BaseSomewhatNeutral(x) && AttackedByMyAllies(x))			->	Enemy(x);
	Alive(x) AND BaseSomewhatNeutral(x) AND NOT Enemy(x) && !TreatAsEnemy(x)		->	Neutral(x);

	FiredAtMe(x)											->	TreatAsEnemy(x);
	DamagedByMeleeSomewhatRecently(x)						->	TreatAsEnemy(x);

	IsLawEnforcement AND Criminal(x)						->  TreatAsEnemy(x);

	// I added this, I think it makes sense. If scripted to kill a particular
	// actor, treat him as en enemy for various purposes. /FF
	ObjectClassObjectiveDestroy(x)							->	TreatAsEnemy(x);

	// If somebody that would normally be treated as a neutral has
	// fired at us, consider him an enemy. TODO: Think about this
	// and make improvements.
	Alive(x) &&  BaseSomewhatNeutral(x) && TreatAsEnemy(x)			->	Enemy(x);
	Alive(x) && !Identified(x) && TreatAsEnemy(x)			->	Enemy(x);

	// If hostile from a conversation, treat as enemy.
	Alive(x) AND HostileFromConversation(x)					->	Enemy(x);

	Enemy(x) || (!Identified(x) && ObjectClassCreature(x))	->	PossibleEnemy(x);

	Enemy(x) && PositionKnownSomewhatRecently(x)							->	EnemiesAreAround;
	Ally(x) && PositionKnownSomewhatRecently(x)								->	AlliesAreAround;
	ObjectClassHuman(x) && Alive(x) && PositionKnownSomewhatRecently(x)		->	AnybodyAround;
}


debuggroup AlliesAndEnemies
{
	filter ObjectClassHuman(x), predicate BaseAlly(x),		label "Base ally $x";
	filter ObjectClassHuman(x), predicate BaseFriendly(x),	label "Base friendly $x";
	filter ObjectClassHuman(x), predicate BaseNeutral(x),	label "Base neutral $x";
	filter ObjectClassHuman(x), predicate BaseHostile(x),	label "Base hostile $x";
	filter ObjectClassHuman(x), predicate BaseEnemy(x),		label "Base enemy $x";
	filter ObjectClassHuman(x), predicate Ally(x),			label "Ally $x";
	filter ObjectClassHuman(x), predicate Enemy(x),			label "Enemy $x";
	filter ObjectClassHuman(x), predicate Neutral(x),		label "Neutral $x";
	filter ObjectClassHuman(x), predicate Identified(x),	label "Identified $x";
	filter ObjectClassHuman(x), predicate TreatAsEnemy(x),	label "Treat as enemy $x";
	filter ObjectClassHuman(x), predicate FiredAtMe(x),		label "Fired at me $x";
	filter TRUE,				predicate EnemiesAreAround,	label "Enemies are around";
	filter TRUE,				predicate IsLawEnforcement,	label "I am law enforcement";
	filter ObjectClassHuman(x), predicate Criminal(x),		label "Criminal $x";
}


rules Misc
{
	Alive(x) AND NOT Identified(x) AND FiredRecently(x) 		->	UnknownWeaponFired(x);
	Enemy(x) AND NOT SeenAfterFiring(x) AND FiredRecently(x)	->	HiddenEnemyWeaponFired(x);

	// If object x is a valid guard objectives, set HasSomethingToGuard, but only
	// if we have the ability to get there. HACK! At the moment having a patrol
	// path overrides guard objectives.
	ObjectClassObjectiveGuard(x) && (At(x) || CanMoveTowards(x)) && !HasPatrolPath ->	HasSomethingToGuard;
}


// This program moves towards a target object if its position is known, if
// it is not it starts searching for the target.
// Goal:			KnowsWhereIs(x) && At(x)	- Get to the target.
// Precondition:	CanFindAndMoveTowards(x)
program FindAndMoveTowards(x)
{
	KnowsWhereIs(x) && At(x)							->	NIL;
	KnowsWhereIs(x)	&& CanMoveTowards(x)				->	MoveTowards(x);
	TRUE												->	Find(x);
}


// MoveTowardsWithoutSearch(x) moves towards the last known position of
// object x, assuming that its still there. If it is realized that the
// object is not at that location (or found somewhere else during the
// process), no search is activated (instead, the precondition
// of the program goes false).
// Goal:			KnowsWhereIs(x) && At(x)	- Get to the target.
// Precondition:	CanMoveTowardsWithoutSearch(x)
program MoveTowardsWithoutSearch(x)
{
	KnowsWhereIs(x) && At(x)										->	NIL;
	KnowsWhereIs(x) && CanMoveTowards(x)							->	MoveTowards(x);

	// This is TRUE assuming that the precondition
	//	CanObserveLastKnownPosition(x) && !NotAtLastKnownPosition(x)
	// is fulfilled.
	TRUE															->	ObserveLastKnownPosition(x);
}


// This program searches for the target until its found.
// Goal:			KnowsWhereIs(x)				- Find out for sure where x is.
// Precondition:	CanFind(x)
program Find(x)
{
	// Check if the goal is fulfilled.
	KnowsWhereIs(x)														-> NIL;

	// If we know a position where the target has been and that we can get to, check that position first.
	CanObserveLastKnownPosition(x) && !NotAtLastKnownPosition(x)		-> ObserveLastKnownPosition(x);

	// If we know a position where the target has been, but has seen that the target is no longer there, search around that position.
	CanSearch(x) && NotAtLastKnownPosition(x)							-> Search(x);

	// The remaining case is for when either we don't have any last known
	// position, or when we have a last known position but has no way of
	// making it visible or otherwise observable.	
	TRUE																-> Search;
}


// ObserveLastKnownPosition(x) moves to a position from which the last known position
// of actor x can be observed (seen).
// Goal:			Observe the last known position.
// Precondition:	CanObserveLastKnownPosition(x)		- Last known position exists and we may be able to get to a location from where it can be seen.
program ObserveLastKnownPosition(x)
{
//	ObservingLastKnownPosition(x)								-> NIL;
	!CanMoveTowards(x) 											-> LookAt(x):(SpeechEvent("MovingToLastKnown", x));

	CanLookAt(x)												-> LookAt(x), MoveTowards(x):(SpeechEvent("MovingToLastKnown", x));

	// TODO: Think about if it's possible to be at the last known position
	// without seeing it, and what the effects would be. /FF
	TRUE														-> MoveTowards(x):(SpeechEvent("MovingToLastKnown", x));
}

// InvestigateBody(x) takes care of finding out the status of a 
// body, x:  is it dead, unconscious, or what?
// Goal:			BodyStatusKnown(x)
// Precondition:	Body(x) AND Close(x)
program InvestigateBody(x)
{
	// Note: I added the Stay action here for stability when invoked in
	// parallel with other programs. /FF
	At(x)				-> PostureCrouch, SpeedWalk, Stay;		// CheckBody(x), SpeedWalk;
	TRUE				-> FindAndMoveTowards(x), SpeedJog;
}

rules Body_Investigation_Rules
{
	Body(x) AND Close(x)				-> CanInvestigateBody(x);
	NOT BodyStatusKnown(x)				-> ShouldInvestigateBody(x);
}

debuggroup BodyInvestigation
{
	filter NOT Player(x), predicate Ally(x),							label "Ally";
	filter NOT Player(x), predicate DeadAlly(x),						label "DeadAlly";
	filter NOT Player(x), predicate Body(x),							label "Body";
	filter NOT Player(x), predicate BodyStatusKnown(x),					label "BodyStatusKnown";
	filter NOT Player(x), predicate CanInvestigateBody(x),				label "CanInvestigateBody";
	filter NOT Player(x), predicate ShouldInvestigateBody(x),			label "ShouldInvestigateBody";
	filter NOT Player(x), predicate ShouldAlertedSearch,				label "ShouldAlertedSearch";
	filter NOT Player(x), predicate ShouldUnalertedSearch,				label "ShouldUnalertedSearch";
}


//-----------------------------------------------------------------------------
// Programs and rules related to keeping your eyes on somebody.

// This program makes the actor look after actor x to see what he/she is
// up to. It involves staying reasonably close and keeping the target
// within sight. This program does not itself react to what the target
// is up to (besides from moving). When this program has reached its
// goal, the actor will look at x but not move.
program KeepEyesOn(x)
{
	CanStayCloseTo(x) && CanMaintainLineOfSight(x)	->	MaintainLineOfSight(x), StayCloseTo(x);

	// Not sure about the order between these:
	CanStayCloseTo(x)								->	StayCloseTo(x);
	TRUE											->	MaintainLineOfSight(x);
}


// Try to maintain line of sight by looking at the target or
// searching for it if lost. This program may have to be extended to really
// try harder to look for the target if it wasn't seen already. That way
// it will probably work better if used together with other behaviors or
// with multiple targets.
program MaintainLineOfSight(x)
{
	// If we know where the target is and can look at it, do so.
	KnowsWhereIs(x) && CanLookAt(x)				->	LookAt(x);

	// If we don't know where the target is, try to find it.
	!KnowsWhereIs(x) && CanFind(x)				->	Find(x);
}


// This small program tries to keep the target within a somewhat close distance.
// It does not invoke a full search action if the target goes out of sight,
// but will move towards the last seen position unless it has been perceived
// that the target is no longer there (in which case the preconditions goes
// false). This program does not care about maintaining visibility, as long
// as the actor thinks or knows that the target is close the goal is considered
// to be achieved.
program StayCloseTo(x)
{
	// If already close, stay where you are.
	Close(x)									->	Stay;

	// Otherwise, move towards the target if it can be done without searching.
	TRUE										->	MoveTowardsWithoutSearch(x);
}


// Preconditions for actions related to keeping track of somebody.
rules Preconditions_KeepEyesOn
{
	// KeepEyesOn(x) basically needs MaintainLineOfSight(x), while
	// StayCloseTo(x) is probably neither sufficient by itself
	// nor required in combination with MaintainLineOfSight(x).
// TEMP: Only for player for now because I didn't have time to look into how this interacts with multiple targets. /FF
Player(x) &&	CanMaintainLineOfSight(x)								->	CanKeepEyesOn(x);

	// If we know where the target is or if we know how to search for it,
	// we can use MaintainLineOfSight(x).
// TEMP: Only for player for now because I didn't have time to look into how this interacts with multiple targets. /FF
Player(x) &&	(KnowsWhereIs(x) || CanFind(x))							->	CanMaintainLineOfSight(x);

	// StayCloseTo() works as long as you know where the target is or if you
	// are already close.
	CanMoveTowardsWithoutSearch(x) || Close(x)				->	CanStayCloseTo(x);
}

//-----------------------------------------------------------------------------
// Programs and rules related to guards dealing with suspicious persons.

// Program that guards can use for dealing with suspicious persons. It can
// be considered a way of realizing the goal of "make sure there are no
// suspicious persons around". This is done by questioning them, and if they
// still seem suspicious we look after them to see what they do.
program DealWithSuspiciousPersons
{
	!EnableDealWithSuspiciousPersons						->	NIL;

	// Question suspicious people that you haven't already questioned.
	Suspicious(x) && !QuestionedSuspicious(x) && CanMoveToAndQuestionSuspicious(x) && Close(x)	->	MoveToAndQuestionSuspicious(x);

	// Keep track of suspicious people that have already been questioned.
	Suspicious(x) && CanKeepEyesOn(x)												->	KeepEyesOn(x);
}


// Move to some suspicious person and start questioning them.
program MoveToAndQuestionSuspicious(x)
{
	KnowsWhereIs(x) && Close(x)								->	ConverseQuestionSuspicious(x), MoveTowardsWithoutSearch(x);

	// CanMoveTowardsAndSearch(x) is a part of the precondition.
	TRUE													->	MoveTowardsWithoutSearch(x);
}


// Preconditions for suspiciousness-related actions.
rules Preconditions_Suspicious
{
	// TODO?
	TRUE													->	CanDealWithSuspiciousPersons;

	// At least for now, only the player can be questioned.
	Player(x) && CanMoveTowardsWithoutSearch(x) && CanConverseQuestionSuspicious(x)	->	CanMoveToAndQuestionSuspicious(x);
}


// Rules dealing with suspicious persons.
rules Rules_Suspicious
{
	// This makes us suspicious of anybody that we have talked that
	// seemed suspicious during the conversation.
	// For now, only the player is considered suspicious.
	Player(x) && SuspiciousFromConversation(x) && Neutral(x)				->	Suspicious(x);
}

//-----------------------------------------------------------------------------
// Programs and rules related to identifying unknown persons.

// This can be used as a stand-alone goal to identify unknown persons.
// Goal:			Identified(x) for all x
// Precondition:	CanIdentifyUnknownPersons
program IdentifyUnknownPersons
{
	!Identified(x) && CanIdentify(x)	->	Identify(x);
}


// This program identifies an actor. Basically an actor becomes identified
// by seeing them at a close enough distance for a long enough time.
// Goal:			Identified(x)
// Precondition:	CanIdentify(x)
program Identify(x)
{
	Identified(x)						->	NIL;
	CanLookAt(x)						->	LookAt(x), MoveTowardsWithoutSearch(x);
	TRUE								->	MoveTowardsWithoutSearch(x);
}


// Preconditions for identification-related programs.
rules Preconditions_Identification
{
	// For now, only alive humans can be identified.
	CanMoveTowardsWithoutSearch(x) && ObjectClassHuman(x) && Alive(x)		->	CanIdentify(x);

	TRUE																	->	CanIdentifyUnknownPersons;
}

//-----------------------------------------------------------------------------
// Programs and rules for retreating.

// A "reason" is the negation of a goal.
rules Reasons_Retreat
{
	CombatClassHealthBelowBreakRetreatHealthPercentageThreshold
		&& CombatClassDamagedWithinBreakRetreatRecoverTime
		&& AllowBehaviorRetreat									->	ShouldRetreat;
}

// Some debugging stuff for retreating.
debuggroup Retreat
{
	filter TRUE, predicate CombatClassHealthBelowBreakRetreatHealthPercentageThreshold, label "CombatClassHealthBelowBreakRetreatHealthPercentageThreshold";
	filter TRUE, predicate CombatClassDamagedWithinBreakRetreatRecoverTime, label "CombatClassDamagedWithinBreakRetreatRecoverTime";
	filter TRUE, predicate AllowBehaviorRetreat, label "AllowBehaviorRetreat";
	filter TRUE, predicate ShouldRetreat, label "ShouldRetreat";
}

//-----------------------------------------------------------------------------
// Rules and debug groups for spatial relationships.

// These are rules processing the raw predicates about the spatial relation between this
// actor and an object x. The predicates on the right-hand side are more refined and suitable
// for general use than the raw predicates (left side) are.
rules Spatial
{
	// Rules for distance predicates with uncertainty:
	SpatialLastObservedDistanceExtremelyClose(x) && PositionKnownVeryRecently(x) -> SpatialDistanceExtremelyClose(x);
	SpatialLastObservedDistanceVeryClose(x) && PositionKnownVeryRecently(x)		-> SpatialDistanceVeryClose(x);
	SpatialLastObservedDistanceClose(x) && PositionKnownRecently(x)				-> SpatialDistanceClose(x);
	SpatialLastObservedDistanceFar(x) && PositionKnownRecently(x)				-> SpatialDistanceFar(x);
	SpatialLastObservedDistanceVeryFar(x) && PositionKnownRecently(x)			-> SpatialDistanceVeryFar(x);

	// This is a helper predicate for determining whether we know the direction to object x reliably or not:
	PositionKnownVeryRecently(x) || (PositionKnownRecently(x) && !SpatialLastObservedDistanceClose(x))	-> SpatialDirectionToKnown(x);

	// Predicates for the direction to object x relative to us.
	SpatialLastObservedDirectionBehindMe(x) && SpatialDirectionToKnown(x)		-> SpatialDirectionBehindMe(x);
	SpatialLastObservedDirectionAheadOfMe(x) && SpatialDirectionToKnown(x)		-> SpatialDirectionAheadOfMe(x);
	SpatialLastObservedDirectionLeftOfMe(x) && SpatialDirectionToKnown(x)		-> SpatialDirectionLeftOfMe(x);
	SpatialLastObservedDirectionRightOfMe(x) && SpatialDirectionToKnown(x)		-> SpatialDirectionRightOfMe(x);
	SpatialLastObservedDirectionAboveMe(x) && SpatialDirectionToKnown(x)		-> SpatialDirectionAboveMe(x);
	SpatialLastObservedDirectionBelowMe(x) && SpatialDirectionToKnown(x)		-> SpatialDirectionBelowMe(x);
	SpatialLastObservedDirBoolLeftOfMe(x) && SpatialDirectionToKnown(x)			-> SpatialDirBoolLeftOfMe(x);
	SpatialLastObservedDirBoolRightOfMe(x) && SpatialDirectionToKnown(x)		-> SpatialDirBoolRightOfMe(x);

	// Helper predicate for the certainty of the position and direction of x combined:
	SpatialDirectionToKnown(x) && DirectionKnownVeryRecently(x)					-> SpatialPositionAndDirectionKnown(x);

	// These are predicates for the this actor's position compared to object x.
	SpatialLastObservedMeBehindObject(x) && SpatialPositionAndDirectionKnown(x)	-> SpatialMeBehindObject(x);
	SpatialLastObservedMeAheadOfObject(x) && SpatialPositionAndDirectionKnown(x)-> SpatialMeAheadOfObject(x);
	SpatialLastObservedMeLeftOfObject(x) && SpatialPositionAndDirectionKnown(x)	-> SpatialMeLeftOfObject(x);
	SpatialLastObservedMeRightOfObject(x) && SpatialPositionAndDirectionKnown(x)-> SpatialMeRightOfObject(x);
	SpatialLastObservedFacingAgainstMe(x) && SpatialPositionAndDirectionKnown(x)-> SpatialFacingAgainstMe(x);

	// Helper predicate for the certainty of object x' position and velocity.
	SpatialDirectionToKnown(x) && VelocityKnownVeryRecently(x)					-> SpatialPositionAndVelocityKnown(x);

	// Predicates for object x' movement relative to us.
	SpatialLastObservedMovingTowardsMe(x) && SpatialPositionAndVelocityKnown(x)	-> SpatialMovingTowardsMe(x);
	SpatialLastObservedMovingAwayFromMe(x) && SpatialPositionAndVelocityKnown(x)-> SpatialMovingAwayFromMe(x);
	SpatialLastObservedMovingCW(x) && SpatialPositionAndVelocityKnown(x)		-> SpatialMovingCW(x);
	SpatialLastObservedMovingCCW(x) && SpatialPositionAndVelocityKnown(x)		-> SpatialMovingCCW(x);

	// Predicates for object x' movement speed.
	SpatialLastObservedMovingSpeedWalking(x) && VelocityKnownVeryRecently(x)	-> SpatialWalking(x);
	SpatialLastObservedMovingSpeedJogging(x) && VelocityKnownVeryRecently(x)	-> SpatialJogging(x);
	SpatialLastObservedMovingSpeedRunning(x) && VelocityKnownVeryRecently(x)	-> SpatialRunning(x);
	SpatialLastObservedMovingSpeedSprinting(x) && VelocityKnownVeryRecently(x)	-> SpatialSprinting(x);
}


// Debug group including processed spatial predicates.
debuggroup SpatialPredicateProcessed
{
	filter Player(x), predicate SpatialDistanceVeryClose(x),					label "VeryClose";
	filter Player(x), predicate SpatialDistanceClose(x),						label "Close";
	filter Player(x), predicate SpatialDistanceFar(x),							label "Far";
	filter Player(x), predicate SpatialDistanceVeryFar(x),						label "VeryFar";

	filter Player(x), predicate SpatialDirectionToKnown(x),						label "DirectionKnown";
	filter Player(x), predicate SpatialDirectionBehindMe(x),					label "BehindMe";
	filter Player(x), predicate SpatialDirectionAheadOfMe(x),					label "AheadOfMe";
	filter Player(x), predicate SpatialDirectionLeftOfMe(x),					label "LeftOfMe";
	filter Player(x), predicate SpatialDirectionRightOfMe(x),					label "RightOfMe";
	filter Player(x), predicate SpatialDirectionAboveMe(x),						label "AboveMe";
	filter Player(x), predicate SpatialDirectionBelowMe(x),						label "BelowMe";

	filter Player(x), predicate SpatialMeBehindObject(x),						label "BehindObject";
	filter Player(x), predicate SpatialMeAheadOfObject(x),						label "AheadOfObject";
	filter Player(x), predicate SpatialMeLeftOfObject(x),						label "LeftOfObject";
	filter Player(x), predicate SpatialMeRightOfObject(x),						label "RightOfObject";
	filter Player(x), predicate SpatialFacingAgainstMe(x),						label "FacingAgainstMe";

	filter Player(x), predicate SpatialMovingTowardsMe(x),						label "MovingTowardsMe";
	filter Player(x), predicate SpatialMovingAwayFromMe(x),						label "MovingAwayFromMe";
	filter Player(x), predicate SpatialMovingCW(x),								label "MovingCW";
	filter Player(x), predicate SpatialMovingCCW(x),							label "MovingCCW";

	filter Player(x), predicate SpatialWalking(x),								label "Walking";
	filter Player(x), predicate SpatialJogging(x),								label "Jogging";
	filter Player(x), predicate SpatialRunning(x),								label "Running";
	filter Player(x), predicate SpatialSprinting(x),							label "Sprinting";
}


// Debug group including raw spatial predicates. These are very sensitive to changes
// and don't take uncertainty of observations into account, so please use the processed
// versions instead whenever possible.
debuggroup SpatialPredicatesRaw
{
	filter Player(x), predicate SpatialLastObservedDistanceVeryClose(x),		label "VeryClose";
	filter Player(x), predicate SpatialLastObservedDistanceClose(x),			label "Close";
	filter Player(x), predicate SpatialLastObservedDistanceFar(x),				label "Far";
	filter Player(x), predicate SpatialLastObservedDistanceVeryFar(x),			label "VeryFar";
	filter Player(x), predicate SpatialLastObservedDirectionBehindMe(x),		label "BehindMe";
	filter Player(x), predicate SpatialLastObservedDirectionAheadOfMe(x),		label "AheadOfMe";
	filter Player(x), predicate SpatialLastObservedDirectionLeftOfMe(x),		label "LeftOfMe";
	filter Player(x), predicate SpatialLastObservedDirectionRightOfMe(x),		label "RightOfMe";
	filter Player(x), predicate SpatialLastObservedDirectionAboveMe(x),			label "AboveMe";
	filter Player(x), predicate SpatialLastObservedDirectionBelowMe(x),			label "BelowMe";

	filter Player(x), predicate SpatialLastObservedMeBehindObject(x),			label "BehindObject";
	filter Player(x), predicate SpatialLastObservedMeAheadOfObject(x),			label "AheadOfObject";
	filter Player(x), predicate SpatialLastObservedMeLeftOfObject(x),			label "LeftOfObject";
	filter Player(x), predicate SpatialLastObservedMeRightOfObject(x),			label "RightOfObject";
	filter Player(x), predicate SpatialLastObservedFacingAgainstMe(x),			label "FacingAgainstMe";

	filter Player(x), predicate SpatialLastObservedMovingTowardsMe(x),			label "MovingTowardsMe";
	filter Player(x), predicate SpatialLastObservedMovingAwayFromMe(x),			label "MovingAwayFromMe";
	filter Player(x), predicate SpatialLastObservedMovingCW(x),					label "MovingCW";
	filter Player(x), predicate SpatialLastObservedMovingCCW(x),				label "MovingCCW";

	filter Player(x), predicate SpatialLastObservedMovingSpeedWalking(x),		label "Walking";
	filter Player(x), predicate SpatialLastObservedMovingSpeedJogging(x),		label "Jogging";
	filter Player(x), predicate SpatialLastObservedMovingSpeedSprinting(x),		label "Sprinting";

	filter Player(x), predicate SpatialLastObservedMovingSpeedCrouchSlow(x),	label "CrouchSlow";
	filter Player(x), predicate SpatialLastObservedMovingSpeedCrouchWalk(x),	label "CrouchWalk";
	filter Player(x), predicate SpatialLastObservedMovingSpeedCrouchFast(x),	label "CrouchFast";
}

//-----------------------------------------------------------------------------

// This gives you a list of all objects of various classes that
// the actor knows about.
debuggroup ObjectClasses
{
	filter ObjectClassAlarm(x),				label "Alarm $x";
	filter ObjectClassCreature(x),			label "Creature $x";
	filter ObjectClassGenderFemale(x),		label "GenderFemale $x";
	filter ObjectClassGenderMale(x),		label "GenderMale $x";
	filter ObjectClassHorse(x),				label "Horse $x";
	filter ObjectClassHuman(x),				label "Human $x";
	filter ObjectClassLocation(x),			label "Location $x";
	filter ObjectClassObjectiveDestroy(x),	label "ObjectiveDestroy $x";
	filter ObjectClassObjectiveGuard(x),	label "ObjectiveGuard $x";
	filter ObjectClassObjectiveMoveTo(x),	label "ObjectiveMoveTo $x";
	filter ObjectClassObjectiveSeekCoverFrom(x),label "ObjectiveSeekCoverFrom $x";
	filter ObjectClassSound(x),				label "Sound $x";
	filter ObjectClassSquadMoveTo(x),		label "SquadMoveTo $x";
	filter ObjectClassVehicle(x),			label "Vehicle $x";
}

//-----------------------------------------------------------------------------

// This lists all known sound objects together with what they are and when they were heard.
debuggroup SoundTimes
{
	filter ObjectClassSound(x), predicate RecentExplosion(x),					label "RecentExplosion $x";
	filter ObjectClassSound(x), predicate RecentLoudNoise(x),					label "RecentLoudNoise $x";
	filter ObjectClassSound(x), predicate RecentProjectileImpact(x),			label "RecentProjectileImpact $x";
	filter ObjectClassSound(x), predicate SomewhatRecentExplosion(x),			label "SomewhatRecentExplosion $x";
	filter ObjectClassSound(x), predicate SomewhatRecentLoudNoise(x),			label "SomewhatRecentLoudNoise $x";
	filter ObjectClassSound(x), predicate SomewhatRecentProjectileImpact(x),	label "SomewhatRecentProjectileImpact $x";
	filter ObjectClassSound(x), predicate VeryRecentExplosion(x),				label "VeryRecentExplosion $x";
	filter ObjectClassSound(x), predicate VeryRecentLoudNoise(x),				label "VeryRecentLoudNoise $x";
	filter ObjectClassSound(x), predicate VeryRecentProjectileImpact(x),		label "VeryRecentProjectileImpact $x";
}

//-----------------------------------------------------------------------------
// Combat-related programs and rules:

program CombatEngageEnemies
{
	// CodeRED Pass3 lasso/takedown pressure: armed NPCs close distance and attempt restraint/takedown before pure gunfire.
	!RidingVehicle && WantToHurt(x) && SpatialDistanceClose(x) && CanCombatFightOrTakeDown(x)										->	CombatFightOrTakeDown(x), LookAtIfPossible(x);
	!RidingVehicle && WantToHurt(x) && !CombatRangeWeaponReadied && CanCombatReadyRangeWeapon							->	CombatReadyRangeWeapon, LookAtIfPossible(x);
	// This is here 3 times to give a preference to close targets, unless already attacked by others.
	// Note that this relies on this being a TR program that's applied to all targets at once,
	// the effect would be different if this was turned into a program EngageEnemy(x).
	ShouldCombatSearchAndAttack(x) && (SpatialDistanceVeryClose(x) && !ManyOthersAreAttacking(x))	 		->	CombatSearchAndAttack(x);
	ShouldCombatSearchAndAttack(x) && (SpatialDistanceClose(x) && !OthersAreAttacking(x))		 			->	CombatSearchAndAttack(x);
	ShouldCombatSearchAndAttack(x)																			->	CombatSearchAndAttack(x);

	// Get on a horse if possible if an enemy is riding.
	!Riding && WantToHurt(x) && Riding(x) && !PrefersWalking && CanMountNearbyHorse							->	MountNearbyHorse, SpeedJog;

	// Jog towards enemies that are far enough away to not be attacked by the CombatSearchAndAttack(x)
	// above, but that nobody else is attacking. This (and the SpeedWalk version of the rule) takes
	// care of this situation:
	// 1. Get close enough to the actor for him to identify you as an enemy.
	// 2. Move far away, but within vision range. Before, the actor would search,
	//    now he should move towards you.
	// Note that this assumes that the actor will be able to attack once he gets close.
	WantToHurt(x) && CanFindAndMoveTowards(x) && !OthersAreAttacking(x)			->	FindAndMoveTowards(x), SpeedJog;

	// If others are already attacking, walk towards distant enemies.
	WantToHurt(x) && CanFindAndMoveTowards(x)									->	FindAndMoveTowards(x), SpeedWalk;
}


// This program involves shooting at target x. If losing sight with the target
// the actor enters a quick search mode. If losing sight of the target for
// an extended period of time, it is intended that the user of this program
// enters a more thorough long-term search or takes other action (such as
// alerting allies directly or setting off an alarm).
// Precondition:	CanCombatSearchAndAttack(x).
program CombatSearchAndAttack(x)
{
	// Since we can't do much in terms of attacking yet while on
	// a horse, dismount for the attack. The exception is if the target
	// is on a horse too, in which case we'll just stay on.
	// TODO:  Resolve the conflict between this autonomous dismount and a TASK_MOUNT
	// SpatialDistanceClose(x) && !Riding(x) && Riding && CanRideDismount								->	RideDismount;

	// If the intended target is riding and we have the opportunity to
	// mount a horse, do so.
	!Riding && Riding(x) && !PrefersWalking && CanMountNearbyHorse										->	MountNearbyHorse, SpeedJog;

	// Fight hand-to-hand under certain conditions (typically if close to x).
	ShouldFightInsteadOfShoot(x) && CanCombatFight(x)	 	->	CombatFight(x);

	// Shoot etc from cover. /FF
	CombatClassShouldStayAtCover && CanCombatUseWeaponsAgainstFromCover(x) && (WasVisibleJustNow(x) || CombatClassCoverWaitTargetPosUnknown(x))	->	CombatUseWeaponsAgainstFromCover(x), CombatSeekCoverToShootAt(x), CombatSeekCoverToProtectFrom(x);

	// Move and shoot, without using cover. /FF
	(KnowsWhereIs(x) || (LastKnownPositionExists(x) && !NotAtLastKnownPosition(x))) && CanCombatShootNew(x)		->	CombatShootNew(x);

	// TODO: There should probably be a rule here to fight. That way, even if
	// we wouldn't have a reason to fight instead of to shoot, we would still
	// fight in case we couldn't shoot.

	// CanFindAndMoveTowards(x) is a part of CanCombatSearchAndAttack(x). Note that
	// this used to be a Find(x) instead of FindAndMoveTowards(x), but in that case an
	// actor that can't shoot would not move close to engage in close combat.
	CanFindAndMoveTowards(x)							->	FindAndMoveTowards(x), SpeedJog;
}


// Useful debug values for combat. They are all shown with the player as the
// intended target.
debuggroup Combat
{
	//filter Player(x), predicate AllowedToFireAt(x),			label "AllowedToFireAt";
	filter Player(x), predicate CanCombatSearchAndAttack(x),	label "CanCombatSearchAndAttack";
	filter Player(x), predicate CanCombatShootNew(x),			label "CanCombatShootNew";
	filter Player(x), predicate CanFind(x),						label "CanFind";
	filter Player(x), predicate CombatTargetFurtherThanWeaponMax(x), label "CombatTargetFurtherThanWeaponMax";
	filter Player(x), predicate CombatTargetFurtherThanWeaponDesired(x),  label "CombatTargetFurtherThanWeaponDesired";
	filter Player(x), predicate Enemy(x),						label "Enemy";
	filter Player(x), predicate KnowsWhereIs(x),				label "KnowsWhereIs";
	filter Player(x), predicate ManyOthersAreAttacking(x),		label "ManyOthersAreAttacking";
	filter Player(x), predicate OthersAreAttacking(x),			label "OthersAreAttacking";
	filter Player(x), predicate NotAtLastKnownPosition(x),		label "NotAtLastKnownPosition";
	filter Player(x), predicate PositionKnownRecently(x),		label "PositionKnownRecently";
	filter Player(x), predicate ShouldCombatSearchAndAttack(x),	label "ShouldCombatSearchAndAttack";
	filter Player(x), predicate SpatialDistanceClose(x),		label "SpatialDistanceClose";
	filter Player(x), predicate SpatialDistanceVeryClose(x),	label "SpatialDistanceVeryClose";
	filter Player(x), predicate SpatialDistanceExtremelyClose(x),label "SpatialDistanceExtremelyClose";
	filter TRUE, predicate HasRangeCapabilities, label "HasRangeCapabilities";
	filter TRUE, predicate CombatClassShouldMoveToCover,		label "CombatClassShouldMoveToCover";
	filter TRUE, predicate CombatClassShouldMoveToCoverStart,	label "CombatClassShouldMoveToCoverStart";
	filter TRUE, predicate CombatClassShouldBeSuppressed,		label "CombatClassShouldBeSuppressed";
	filter TRUE, predicate CombatClassShouldBeSuppressedStart,	label "CombatClassShouldBeSuppressedStart";
	filter TRUE, predicate CombatClassCoverGoodOrWaiting,		label "CombatClassCoverGoodOrWaiting";
}


debuggroup Activities
{
	// Well, this is sort of like an enum.
	filter TRUE, predicate ReadyToIdle, label "ReadyToIdle";
	filter TRUE, predicate ReadyToShootFromCoverAgain, label "ReadyToShootFromCoverAgain";
	filter TRUE, predicate ReadyToReload, label "ReadyToReload";
}

rules Activities
{
	// A modest substitute for an enum.  Obviously good only 
	// for the conditions and not the actions.  
	// TODO:  different, less general-purpose-sounding names?
	ActivityReadyToPerform(0) -> ReadyToIdle;					// Activity #0 = kActivityFutureIdling
	ActivityReadyToPerform(1) -> ReadyToShootFromCoverAgain;	// Activity #1 = kActivityFutureShootFromCoverAgain
	ActivityReadyToPerform(2) -> ReadyToReload;					// Activity #2 = kActivityFutureReload
}

// Precondition rules for combat actions.
rules Preconditions_Combat
{
	(HasRangeCapabilities || HasFightCapabilities) &&
	(	(((KnowsWhereIs(x) || !NotAtLastKnownPosition(x)) && CanCombatShootNew(x))
	||	(ShouldFightInsteadOfShoot(x) && CanCombatFight(x)) ) || CanFindAndMoveTowards(x))				->	CanCombatSearchAndAttack(x);

	// Precondition for CombatShootNoCoverMove(x) program. Note that it currently
	// checks if the range weapon has ammo while this is not really required, though
	// the program is probably not useful otherwise anyway and there is no predicate
	// yet for range weapon with or without ammo.
	CombatRangeWeaponReadied && ((!CombatTargetObstructed(x) && !CombatTargetFurtherThanWeaponDesired(x)) || CanMoveTowards(x))			->	CanCombatShootNoCoverMove(x);

	// Check if we're performing something that we don't want to allow shooting or facing
	// during, unless NoCoverAllowShootWhileMoving is set in the combat class. /FF
	// - Update: I added the !Riding part here. While it's possible that we want to control
	//   the ability to shoot while riding somewhere, the intention of NoCoverAllowShootWhileMoving
	//   was to make a distinction between actors that should strafe and ones that shouldn't,
	//   during on-foot combat, but it made certain ("grunt" style) actors not shoot from
	//   horseback. /FF
	(!CombatClassNoCoverAllowShootWhileMoving && EventActive("DisallowShootAndFace") && !Riding)	->	DisallowShootAndFace;

	// CanCombatShootNoCover(x) can't be executed if moving to cover etc and the combat class doesn't allow it (see DisallowShootAndFace). /FF
	(!DisallowShootAndFace) && (CanCombatShootNoCoverMove(x) || CanCombatUseWeaponsAgainst(x))												->	CanCombatShootNoCover(x);

	(CombatAtCover && CanCombatUseWeaponsAgainstFromCover(x)) || CanCombatShootNoCover(x)													->	CanCombatShootFromCoverOrNot(x);

	CombatWeaponDrawnRangeLoaded && !ReadyToReload -> CombatRangeWeaponReadied;

	// Precondition for CombatReadyRangeWeapon program.
	CombatWeaponDrawnRangeLoaded || (CombatWeaponDrawn && CanCombatWeaponLoad) || CanCombatWeaponDrawRange									->	CanCombatReadyRangeWeapon;

	(!CombatRangeWeaponReadied && CanCombatReadyRangeWeapon) || CanCombatShootFromCoverOrNot(x)									->	CanCombatShootOrDrawWeapon(x);

	CanCombatShootOrDrawWeapon(x)																											->	CanCombatShootNew(x);

	(ShouldCombatSearchAndAttack(x) || (WantToHurt(x) && CanFindAndMoveTowards(x))) && (HasRangeCapabilities || HasFightCapabilities)
																																			->	CanCombatEngageEnemies;

	// Precondition for the CombatUseWeaponsAgainst(x) program.
	CanCombatShoot(x) || CanCombatThrowExplosivesAt(x)																						->	CanCombatUseWeaponsAgainst(x);

	// Precondition for the CombatUseWeaponsAgainstFromCover(x) program.
	//CanCombatShootFromCover(x) || CanCombatThrowExplosivesAtFromCover(x)																	->	CanCombatUseWeaponsAgainstFromCover(x);
	// Updated, to reflect better what the program does now. Maybe this should be a more complete precondition, but for now
	// this simply one may work, as the program would at least be able to do something as long as CanCombatHideAtCover is true. /FF
	CombatAtCover && CanCombatHideAtCover																									->	CanCombatUseWeaponsAgainstFromCover(x);

	// TODO: Implement this predicate in code.
	TRUE									->	HasFightCapabilities;
}

// General rules related to combat.
rules Rules_Combat
{
	// If this is true, we can expect to have some sort of long range attack.
	// It will be true even if a gun is not drawn right now.
	CanCombatWeaponDrawRange || CombatHasThrowableExplosives				->	HasRangeCapabilities;

	CombatClassCloserThanFightIfCloserThanDistance(x) && PositionKnownVeryRecently(x)
		&& (!SpatialMovingAwayFromMe(x) || !CombatClassShootDontFightIfTargetRunsAway)	->	ShouldFightInsteadOfShoot(x);

	MeleeForced 	->	ShouldFightInsteadOfShoot(x);

	// We want to hurt enemy creatures.
	AttackOnSight && ObjectClassCreature(x) && Enemy(x)		->	BaseWantToHurt(x);

	ObjectClassObjectiveDestroy(x) && Alive(x)		->	BaseWantToHurt(x);

	BaseWantToHurt(x) AND NOT WantNotToHurt(x)		->	WantToHurt(x);

	// For now, there are no limitations to whom you are allowed to shoot.
	// For certain guards this should probably include that you are not
	// allowed to fire back until fired upon.
	//TRUE								->	AllowedToFireAt(x);

	// TODO: Connect these up to be true if others are already attacking that target,
	// so we can potentially pick another and distribute the attacks.
	FALSE								->	ManyOthersAreAttacking(x);
	FALSE								->	OthersAreAttacking(x);

	// Detect if actor x is aiming at us.
	CombatAimingAtMeWhenVisible(x) && WasVisibleVeryRecently(x)		->	AimingAtMe(x);

	// Detect if enemies are really close.
	Enemy(x) && SpatialDistanceVeryClose(x)							->	VeryCloseToEnemies;

	// Detect if under fire.
	// Disregard if enemies are nearby. This is a simple fix for actors thinking they
	// are under fire when an ally is instead shooting at a nearby enemy. TODO: Find a better solution. /FF
	!VeryCloseToEnemies && DamagedByProjectileVeryRecently								->	UnderFire WITH 0.4;
	!VeryCloseToEnemies && VeryRecentProjectileImpact(x) && SpatialDistanceVeryClose(x)	->	UnderFire WITH 0.2;
	!VeryCloseToEnemies && SomewhatRecentProjectileImpact(x) && SpatialDistanceClose(x)	->	UnderFire WITH 0.2;

	SpatialMovingAwayFromMe(x) && SpatialSprinting(x)									->	SprintingAway(x);
	//SpatialMovingAwayFromMe(x) && (SpatialJogging(x) || SpatialSprinting(x))			->	RunningAway(x);

	// Note: this used to include PositionKnownRecently(x), but that's no good for combat behaviors
	// that may include waiting at cover for the target to show up. /FF
	// Note: this seems strange to me when I look at it now - basically, if there is no range weapon
	// this will be true regardless of distance, but if there is one, it will be false beyond the
	// weapon's range. I'm leaving it like this for now. /FF
	// Note: I added the !CombatWeaponDrawn && CanCombatWeaponDrawRange() since HasRangeCapabilities
	// also considers weapons currently not drawn while CombatTargetFurtherThanWeaponMax(x) doesn't.
	// Before, there was a glitch that would frequently cause this predicate to be false when it shouldn't. /FF
	WantToHurt(x) && CanCombatSearchAndAttack(x) && (!HasRangeCapabilities || (!CombatTargetFurtherThanWeaponMax(x) || (!CombatWeaponDrawn && CanCombatWeaponDrawRange)))	->	ShouldCombatSearchAndAttack(x);

	// This is true when at cover that's "good", or if that cover has been "good" within a time
	// limit specified in the combat class. /FF
	CombatAtCover && CombatClassCoverGoodOrWaiting										->	CombatClassShouldStayAtCover;
}


rules Rules_Threats
{
	// <TITLE CombatRangeWeaponDrawn(x)>
	// PURPOSE:	True if we believe that x currently has a range weapon drawn.
	CombatRangeWeaponDrawnWhenVisible(x) && WasVisibleRecently(x)	->	CombatRangeWeaponDrawn(x);

	// <TITLE WithinTargetsWeaponRange(x)>
	// PURPOSE:	Assuming that x has a range weapon, are we within its effective range?
	SpatialDistanceClose(x)											->	WithinTargetsWeaponRange(x);

	// <TITLE TargetHasLineOfSightToMe(x)>
	// PURPOSE:	There is nothing between x and me that would prevent x from shooting.
	// TODO:	Implement somehow.
	TRUE															->	TargetHasLineOfSightToMe(x);

	// <TITLE ImmediateCouldShootMe(x)>
	// PURPOSE:	If x wants to and knows where and who we are, he could shoot us right now.
	CombatRangeWeaponDrawn(x) && WithinTargetsWeaponRange(x) && TargetHasLineOfSightToMe(x)		->	ImmediateCouldShootMe(x);

	// <TITLE InGunfight>
	// PURPOSE:	There is some sort of gunfight going on where we're currently at.

	// If somebody fired a gun somewhere nearby, we're in a gunfight.
	FiredSomewhatRecently(x) && SpatialDistanceClose(x)				->	InGunfight;

	// If we're under fire, consider us to be in a gunfight.
	UnderFire														->	InGunfight;

	// <TITLE LikelyToFireRangeWeapon(x)>
	// PURPOSE:	Assuming that x has a range weapon, wants to hurt us, and is
	//			able to fire at us from where he is, LikelyToFireRangeWeapon(x)
	//			if it's likely that he would. For example, a civilian may not
	//			know how to shoot a gun and law enforcement may not be allowed
	//			to unless fired upon.
	HasFired(x) || InGunfight										->	LikelyToFireRangeWeapon(x);

	// <TITLE ImmediateWantsToHarmMe(x)>
	// PURPOSE:	If true, it means that actor x seems to have hostile intentions
	//			and is likely to harm us right now if he had the chance.
	AimingAtMe(x)	->	ImmediateWantsToHarmMe(x);
	Enemy(x)		->	ImmediateWantsToHarmMe(x);

	// <TITLE ImmediateThreat(x)>
	// PURPOSE:	If true, we think that x wants to hurt us, knows about us, and
	//			has some way of hurting us within a few seconds.
	ImmediateCouldShootMe(x) && LikelyToFireRangeWeapon(x) && ImmediateWantsToHarmMe(x) && KnowsAboutMe(x) && !SprintingAway(x)			->	ImmediateThreat(x);

	// TODO: This condition probably needs a lot of work.
	Enemy(x) && FiredRecently(x)									->	HighThreat(x);
}


debuggroup Threats
{
	filter TRUE, predicate InGunfight, label "In gunfight";
	filter TRUE, predicate UnderFire, label "Under fire";
	filter ObjectClassHuman(x), predicate KnowsAboutMe(x),			label "$x knows about me";
	filter ObjectClassHuman(x), predicate ImmediateCouldShootMe(x),	label "Immediate $x could shoot me";
	filter ObjectClassHuman(x), predicate ImmediateWantsToHarmMe(x),label "Immediate $x wants to harm me";
	filter ObjectClassHuman(x), predicate ImmediateThreat(x),		label "Immediate threat $x";
	filter ObjectClassHuman(x), predicate HighThreat(x),			label "High threat $x";
}


// This is the replacement for the old in-code CombatShoot behavior. It makes
// the actor draw his weapon and look at and shoot at x, trying to not get
// outside of range for the weapon. It also modifies the cover-seeking
// scoring function to try to shoot at x and be protected from it firing back.
// Note that it does not by itself make the actor actually move to cover,
// other programs are responsible for that.
// Precondition:	CanCombatShootNew(x)
program CombatShootNew(x)
{
	// Note: this uses CombatSeekCoverToShootAt(x) and CombatSeekCoverToProtectFrom(x) without testing preconditions.
	// TODO: Fix.
	TRUE							->	CombatShootOrDrawWeapon(x), CombatSeekCoverToShootAt(x), CombatSeekCoverToProtectFrom(x);
}


// This program makes the actor have a drawn and loaded gun.
// Goal:			CombatRangeWeaponReadied
// Precondition:	CanCombatWeaponRangeDrawAndLoad
program CombatReadyRangeWeapon
{
	CombatRangeWeaponReadied																			->	NIL;

	// TODO: cover case for ReadyToReload

	// NOTE:  not sure these all need CancelPlannedActivity(2), 
	// but it doesn't hurt.  (Of course, arguably, all reloads 
	// should do it on the code side...)

	// If hidden at cover and we can reload, do it.
	CombatWeaponDrawn && CanCombatWeaponLoad && CombatAtCover && CombatAtCoverHidden && CanCombatHideAtCover->	CombatWeaponLoad, CombatHideAtCover, CancelPlannedActivity(2);

	// If at cover but not hidden, hide first so we can reload while behind cover.
	CombatWeaponDrawn && CanCombatHideAtCover && CombatAtCover												->	CombatHideAtCover;

	// Sometimes we want to reload before it's entirely necessary (for gameplay effect)
	ReadyToReload && CanCombatWeaponLoad																	->  CombatWeaponLoad, CancelPlannedActivity(2);
	
	// Not at cover, so just reload the weapon.
	CombatWeaponDrawn && CanCombatWeaponLoad																->	CombatWeaponLoad, CancelPlannedActivity(2);

	// No weapon drawn, so draw it now.
	TRUE																									->	CombatWeaponDrawRange;
}


// Shoot with actor x as target if the weapon is already drawn, otherwise draw
// the weapon first. Note: this currently also allows for using explosives, not
// just shooting guns.
// Precondition:	CanCombatShootOrDrawWeapon(x)
program CombatShootOrDrawWeapon(x)
{
	!CombatRangeWeaponReadied && CanCombatReadyRangeWeapon		->	CombatReadyRangeWeapon, LookAtIfPossible(x);
	TRUE														->	CombatShootNoCover(x), DodgeImpacts;
}


// This program makes the actor shoot at x in a way that's appropriate when
// there is no cover around. It handles body and head movement as well as aiming
// and firing.
// Precondition:	CanCombatShootNoCover(x)
program CombatShootNoCover(x)
{
	TRUE	->
		CombatShootNoCoverA(x),
		CombatShootNoCoverB(x), 
		CombatShootNoCoverC(x),
		DodgeWhenAttackedBy(x),
		SimpleEliteMovement(x);
}

// Used internally by CombatShootNoCover(x).
program CombatShootNoCoverA(x)
{
	CanCombatShootNoCoverMove(x)	->	CombatShootNoCoverMove(x);
}

// Used internally by CombatShootNoCover(x).
program CombatShootNoCoverB(x)
{
	CanCombatUseWeaponsAgainst(x)		->	CombatUseWeaponsAgainst(x);
}

// Used internally by CombatShootNoCover(x).
program CombatShootNoCoverC(x)
{
	CanLookAt(x)					->	LookAt(x);
}

// While in combat with no cover and at the desired range of a weapon, this program
// controls the posture of the character.
program CombatShootNoCoverStillPosture(tgt)
{
	// If an ally is between us and the target, stand up.
	CombatClassNoCoverStandBehindAlly && Ally(x) && SpatialDistanceVeryClose(x) &&
			SpatialLastObservedBetweenMeAndObject(x, tgt)													->	PostureStand;

	// If we moved very recently, stand up. This is just to prevent frequent standing
	// and crouching switches.
	CombatClassNoCoverNoCrouch																				->	PostureStand;

	// If we are between an ally and an enemy (note: this uses what we think of as an enemy, which
	// could be different from who the ally considers an enemy), crouch.
	CombatClassNoCoverCrouchInFrontOfAlly && Ally(x) && SpatialDistanceVeryClose(x) && Enemy(y) &&
			SpatialLastObservedMeBetweenObjects(x, y)														->	PostureCrouch;
}


// Used by CombatShootNoCover(x) for the movement part of the behavior.
// Basically, they will jog towards the target if the target is further
// away than what's desired or if the target is behind some obstacle
// so that it can't be shot at. Note that for this to work properly you
// need to make sure that you're also looking at the target, as
// CombatTargetObstructed(x) will be true if outside of the vision cone.
// Goal:			!CombatTargetObstructed(x) && !CombatTargetFurtherThanWeaponDesired(x)
// Precondition:	CanCombatShootNoCoverMove(x)
program CombatShootNoCoverMove(x)
{
	// Stay where you are if the target is not obstructed, is not too far away, and is not running away.
	// Note that this weighting between Stay/MoveTowards works to stabilize the program
	// so that there is no strobing if the program is invoked on more than one target
	// simultaneously. Please don't mess with it unless you test it with multiple targets. /FF
	CanMoveTowards(x) && !CombatTargetObstructed(x) && 
		!CombatTargetFurtherThanWeaponDesired(x) && !SprintingAway(x)		->	Stay WITH 1.6, MoveTowards(x) WITH 0.8, CombatShootNoCoverStillPosture(x);

	// Otherwise, move towards the target.
	CanMoveTowards(x)													->	MoveTowards(x) WITH 0.8, SpeedJog, PostureStand;

	// The preconditions assure that we have line-of-sight.  Untested as of 4/25/05.
	TRUE																->	Stay WITH 2.0, CombatShootNoCoverStillPosture(x);
}


// This program makes use of currently available range weapons to attack
// a specific target. This came in existence by replacing use of CombatShoot,
// so that explosives and pistols/rifles are available for use in a number
// of places (while doing something else, as well as when in dedicated combat).
// Precondition:	CanCombatUseWeaponsAgainst(x)
program CombatUseWeaponsAgainst(x)
{
	CombatClassExplosivesPreference && CanCombatThrowExplosivesAt(x)	->	CombatThrowExplosivesAt(x);

	CanCombatShoot(x)													->	CombatShoot(x);

	// CanCombatShoot(x) and CanCombatThrowExplosivesAt(x) are already parts of
	// the precondition for this program, so this should be valid:
	TRUE																->	CombatThrowExplosivesAt(x);
}


// This works like CombatUseWeaponsAgainst(x), but is for use from a cover position.
// Precondition:	CanCombatUseWeaponsAgainstFromCover(x)
program CombatUseWeaponsAgainstFromCover(x)
{
	// If we can and prefer to, use explosives. /FF
	CombatClassExplosivesPreference && CanCombatThrowExplosivesAtFromCover(x)	->	CombatThrowExplosivesAtFromCover(x);

	// If we've got a loaded gun and either don't want to hide between the bursts or we're ready to fire
	// again, shoot at the target. This can be done either if we currently see the target, or if our
	// combat class specifies that we should shoot at the last known position anyway. /FF
	CombatRangeWeaponReadied && ReadyToShootFromCoverAgain &&
			(WasVisibleJustNow(x) || CombatClassCoverShouldShootAtLastKnown(x)) && CanCombatShootFromCover(x)									->	CombatShootFromCover(x);

	// Ready our weapon if we can. CombatReadyRangeWeapon already involves hiding if at a cover location. /FF
	!CombatRangeWeaponReadied && CanCombatReadyRangeWeapon																			->	CombatReadyRangeWeapon, LookAtIfPossible(x), PrepareForActivity(1);

	// If set to hide between bursts and we're not planning on firing the next burst
	// right now, go back to the hidden position and work on that plan. However, peek if possible
	// and we haven't gotten any information about the target's position for a time specified
	// in the combat class. /FF
	!ReadyToShootFromCoverAgain && CanCombatPeekFromCover && !CombatClassCoverPeekTargetPosUnknown(x)		->	CombatPeekFromCover, PrepareForActivity(1);
	!ReadyToShootFromCoverAgain																				->	CombatHideAtCover, PrepareForActivity(1);

	// I guess the purpose of this is to make sure we get to a shooting position even if we don't see the
	// target. This was adapted from some older programs, before we had the peeking, so we might want
	// to re-evaluate if this is really needed. /FF
	CanCombatBeReadyToShootFromCover(x)																											->	CombatBeReadyToShootFromCover(x);

	CanCombatThrowExplosivesAtFromCover(x)																										->	CombatThrowExplosivesAtFromCover(x);

	// Peek if possible and we haven't gotten information about the target for a while.
	CanCombatPeekFromCover && !CombatClassCoverPeekTargetPosUnknown(x)																			->	CombatPeekFromCover;

	// If none of the above applies, hide.
	TRUE																																		->	CombatHideAtCover;
}


program GetBehindCoverIfUnderFire
{
	// TODO: Make use of CombatClassShouldBeSuppressedStart here? /FF

	// If already at cover, get behind if suppressed by hostile fire. /FF
	CombatAtCover && CombatClassShouldBeSuppressed											->	GetBehindCover WITH 2.0;

	// If not at cover, move towards cover if the amount of hostile fire
	// is sufficient according to our combat class. /FF
	!CombatAtCover && CombatClassShouldMoveToCoverStart									->	GetBehindCover WITH 2.0;

	// Continue moving even if dropped below the threshold, for a delay specified by the combat class. /FF
	!CombatAtCover && CombatClassShouldMoveToCover && EventActive("MovingToCover")			->	GetBehindCover WITH 2.0;
}


program GetToCoverIfThreatened
{
// Note: I disabled this - maybe we want something like this, but for now
// the decision of when to take cover is made primarily by GetBehindCoverIfUnderFire. /FF
//	HighThreat(x) && !HasMoveObjective							->	GetToCover WITH 2.0;
}


program SeekCoverFromEnemies
{
	HighThreat(x)												->	CombatSeekCoverToProtectFrom(x) WITH 1.0;
}


// Precondition:	CanGetToCover
program GetToCover
{
	// If currently at good cover or if no better cover is available (!CanCombatMoveToCover),
	// stay where we are. However, if we've been injured by something while we did not
	// consider this cover "good", it's an indication that it really is no good and
	// this program will not do anything, so that other programs are likely to do
	// something to leave cover.
	// NOTE: This really must include staying at the cover location upon reaching it, like it does now:
	CombatAtCover && (CombatAtCoverGood || (!CanCombatMoveToCover && !InjuredWhileAtThisNoGoodCover))		->	CombatStayAtCover;
	
	CanCombatMoveToCover		
		->	CombatMoveToCover:(SpeechEvent("MovingToCover"), SpeechEvent("DisallowShootAndFace")),
			DodgeWhileRetreating;

	// Note: if you make changes here, please consider keeping CanGetToCover up to date.
}


// Precondition:	CanGetBehindCover
program GetBehindCover
{
	CombatAtCover												->	CombatHideAtCover;
	TRUE														->	GetToCover;

	// Note: if you make changes here, please consider keeping CanGetBehindCover up to date.
}

debuggroup Cover
{
	filter TRUE, predicate CombatAtCover, label "CombatAtCover";
	filter TRUE, predicate CombatAtCoverGood, label "CombatAtCoverGood";
	filter TRUE, predicate CanCombatMoveToCover, label "CanCombatMoveToCover";
	filter TRUE, predicate InjuredWhileAtThisNoGoodCover, label "InjuredWhileAtThisNoGoodCover";
}

//-----------------------------------------------------------------------------
// Search-related programs and rules:

// This program executes an unalerted undirected search. The actor
// will be walking. At the moment, it specifies nothing about weapon
// drawing or holstering.  This program doesn't react to anything that it
// finds; it's up to the user to do that.
// Precondition:	CanUnalertedSearch
program UnalertedSearch
{
	// Start a walking search
	TRUE		->	Search, SpeedWalk;
}

// This program executes an alerted undirected search. The actor
// will be jogging and draw his gun if he has one. This program doesn't
// reach to anything that it finds, it's up to the user to do that.
// Precondition:	CanAlertedSearch
program AlertedSearch
{
	// Start a jogging search with a simultaneous goal of trying
	// to draw a weapon.
	TRUE		->	Search, SpeedJog, AlertedSearch_DrawWeaponIfPossible;
}


// Used internally by AlertedSearch.
// Precondition:	TRUE
program AlertedSearch_DrawWeaponIfPossible
{
	CombatRangeWeaponReadied	->	NIL;
	CanCombatReadyRangeWeapon	->	CombatReadyRangeWeapon;
}


// This used to be an elementary action, but isn't anymore. It uses the
// MoveSearch and LookAround elementary actions together.
// Precondition:	CanSearch
program Search
{
	CanLookAround && CanMoveSearch			->	LookAround, MoveSearch;
	CanMoveSearch							->	MoveSearch;

	TRUE /* = CanLookAround */				->	LookAround;
}


// This used to be an elementary action, but isn't anymore. It uses the
// MoveSearch(x) and LookAround elementary actions together.
// Precondition:	CanSearch(x)
program Search(x)
{
	CanLookAround && CanMoveSearch(x)		->	LookAround, MoveSearch(x);
	TRUE /* CanMoveSearch(x) */				->	MoveSearch(x);
}


// Search-related action preconditions.
rules Preconditions_Search
{
	// Allow Search program to be used as long as you can look around
	// or move around.
	CanLookAround || CanMoveSearch							->	CanSearch;

	// Allow Search(x) program MoveSearch(x) can execute. The LookAround
	// part is optional.
	CanMoveSearch(x)										->	CanSearch(x);		// Elementary action.

	// To do an alerted search, we need to be able to search. Note that
	// even though the program will draw a weapon if it's available,
	// it's not a requirement.
	CanSearch							->	CanAlertedSearch;

	// To do an unalerted search, we need to be able to search.
	CanSearch							->	CanUnalertedSearch;
}

// Search-related action justifications.
rules Reasons_Alerted_Search
{
	// If there are enemies around, start an alerted search.
	EnemiesAreAround						-> ShouldAlertedSearch;

	// If one of our allies got killed, start looking for the culprit
	DeadAlly(x)	AND BodyStatusKnown(x)		->	ShouldAlertedSearch;

	// If one of our allies got damaged, start looking for the culprit
	TookDamageRecently(x) AND Ally(x)		->	ShouldAlertedSearch;

	// Go into "alerted search mode" after taking damage from a projectile.
	DamagedByProjectileSomewhatRecently		-> ShouldAlertedSearch;

	// Go into "alerted search mode" after hearing a projectile hit something
	// near us. Since this condition tends to trigger a dive right
	// when the sound is heard, typically this rule makes sure that
	// after diving you start an alerted search. This rule used
	// to start an unalerted search. /FF
	SomewhatRecentProjectileImpact(x)				-> ShouldAlertedSearch;
}

// Search-related action justifications.
rules Reasons_Unalerted_Search
{
	// If we heard an explosion and we have finished investigating it, 
	// look around to see if we can identify its source.
	SomewhatRecentExplosion(x) AND Investigated(x)	-> ShouldUnalertedSearch;

	// Go into "unalerted search mode" after being recently injured by an explosion.
	DamagedByExplosionSomewhatRecently				-> ShouldUnalertedSearch;
}

//-----------------------------------------------------------------------------
// Programs and rules related to how to look at something, involving head
// movement and body turning.

// Convenience program for using LookAt(x) whenever it's possible, useful
// if executing things in parallel.
program LookAtIfPossible(x)
{
	CanLookAt(x)		->	LookAt(x);
}


// Convenience program for using LookAt(x) whenever it's possible, useful
// if executing things in parallel.
program LookIntentlyAtIfPossible(x)
{
	CanLookAtInternal(x)		->	LookAtInternal(x);
}


// This is what other TR programs should use if they want to look at an object
// x. It is done in a way so that it's stable for use with multiple targets and
// should switch between them as appropriate without strobing.
// Precondition:	CanLookAt(x)
program LookAt(x)
{
	BecameVisibleVeryRecently(x) || !WasVisibleRecently(x)	->	LookAtInternal(x) WITH 1.0;
	TRUE													->	LookAtInternal(x) WITH 0.6;
}

// This is used internally by LookAt(x)
// Precondition:	CanLookAtInternal(x)
program LookAtInternal(x)
{
	CanHeadLookAt(x) && CanFace(x) && !DisallowShootAndFace					->	HeadLookAt(x), Face(x);

	// When riding, LookAtInternal extends its angle of usefulness by aiming if the target is behind,
	// which allows the head to turn more than otherwise possible (by turning more of the body).
	Riding && CanCombatAimAtLastKnownPos(x) && SpatialDirectionBehindMe(x) ->	CombatAimAtLastKnownPos(x) WITH 4.0;

	// I added this, for AI actors on vehicles. They tend to have a hard time looking around
	// otherwise, so by allowing them to aim to look for their enemies they can be
	// more observant. /FF
	RidingVehicle && CanCombatAimAtLastKnownPos(x)	->	CombatAimAtLastKnownPos(x) WITH 4.0;

	CanHeadLookAt(x)								->	HeadLookAt(x);
	CanFace(x) && !DisallowShootAndFace				->	Face(x);
}

// Preconditions for "look at"-related actions.
rules Preconditions_LookAt
{
	// The LookAt(x) program uses LookAtInternal(x) and nothing else.
	CanLookAtInternal(x)										->	CanLookAt(x);

	// If we can turn to face the target or we can turn the head to look at
	// the target, LookAtInternal(x) is possible to use.
	(CanFace(x) && !DisallowShootAndFace) || CanHeadLookAt(x) ||
			(Riding && CanCombatAimAtLastKnownPos(x) && SpatialDirectionBehindMe(x)) ||
			(RidingVehicle && CanCombatAimAtLastKnownPos(x))
																->	CanLookAtInternal(x);
}


// These are probably universally useful and maybe should be moved
// out from this section:
rules Rules_LookAt
{
	// If x is visible right now and very recently was not visible, x became visible
	// very recently.
	WasVisibleJustNow(x) && WasNotVisibleVeryRecently(x)		->	BecameVisibleVeryRecently(x);

	// If x is not visible right now but was visible a short time ago, x became
	// not visible very recently.
	WasNotVisibleJustNow(x) && WasVisibleVeryRecently(x)		->	BecameNotVisibleVeryRecently(x);
}

//-----------------------------------------------------------------------------
// Programs and preconditions related to the TASK_FOLLOW_ACTOR script command,
// i.e. following somebody without being a part of the squad/posse.

rules Preconditions_Follow
{
	// FollowMove(x) is really the only part of FindAndFollow(x) that we
	// need to care about for the precondition.
	CanFollowMove(x)		->	CanFindAndFollow(x);

	// FollowMove(x) can be executed if we lost x but know how to find him,
	// if we're not where we want to be but are able to get there, or if
	// we're already where we're supposed to be.
	(!PositionKnownRecently(x) && CanFind(x))
	||	(SpatialMovingAwayFromMe(x) || !SquadMemberAt(x)) && CanMoveTowards(x)
	||	SquadMemberAt(x)	->	CanFollowMove(x);
}


// Follow x if we know where he/she is, or find him/her if not. This program
// adaps speeds and makes sure to look at the person being followed.
// Precondition:	CanFindAndFollow(x)
program FindAndFollow(x)
{
	TRUE				->	FollowMatchSpeed(x), FollowLookAt(x), FollowMove(x);
}


// Called by FindAndFollow(x) mainly for deciding where to move to.
// Precondition: CanFollowMove(x)
program FollowMove(x)
{
	!PositionKnownRecently(x) && CanFind(x)											->	Find(x);
	(SpatialMovingAwayFromMe(x) || !SquadMemberAt(x)) && CanMoveTowards(x)			->	MoveTowards(x);
	CanLookAt(x)																	->	LookAt(x), Stay;
	TRUE																			->	Stay;
}


// This is a helper program that makes sure to look at the person
// we're supposed to follow, if we can.
program FollowLookAt(x)
{
	CanLookAt(x)					->	LookAt(x);
}


// Helper program for controlling the movement speed when
// following somebody.
program FollowMatchSpeed(x)
{
	// Handle the case when we're riding and x is not.
	Riding && !Riding(x)		->	FollowMatchSpeedHorseToFoot(x);

	// Handle the case when x is riding and we are not.
	!Riding && Riding(x)		->	FollowMatchSpeedFootToHorse(x);

	// If getting here, we're either both on horses, or both walking.

	// If x is sprinting, sprint.
	// Note: the 2.0 strength here is mostly because SpatialSprinting(x)
	// isn't perfect at determining the speed. /FF
	SpatialSprinting(x)				->	SpeedSprint WITH 2.0;

	// If x is running, run. This is only valid if we're riding,
	// since this speed doesn't really exist when on foot.
	Riding && SpatialRunning(x)		->	SpeedRun;

	// If riding (both of us), use run speed unless very close to the target.
	Riding && !SpatialDistanceVeryClose(x)		->	SpeedRun;

	// If we're not very close, don't bother trying to walk, better
	// start jogging.
	!SpatialDistanceVeryClose(x)	->	SpeedJog;

	// Even if we're close, if the target is jogging we probably should too,
	// to not get behind wherever he's going.
	SpatialJogging(x)				->	SpeedJog;

	// If here, we're very close to x, and x isn't moving faster than
	// at walk speed.
	TRUE							->	SpeedWalk;
}


// Used by FollowMatchSpeed(x) when riding and following
// somebody that's on foot.
program FollowMatchSpeedHorseToFoot(x)
{
	// If we're somewhat far off, catch up.
	!SpatialDistanceClose(x)		->	SpeedRun;

	// If x is sprinting (on foot), we can use the run
	// speed. No need to sprint.
	SpatialSprinting(x)				->	SpeedRun;

	// Unless x is very close, jog to get to him.
	!SpatialDistanceVeryClose(x)	->	SpeedJog;

	// x is jogging but is very close. A horse "jog" isn't currently
	// much faster than an on-foot jog, so let's keep up with his speed.
	SpatialJogging(x)				->	SpeedJog;

	// x is very close, and not moving fast. Let's walk.
	TRUE							->	SpeedWalk;
}


program FollowMatchSpeedFootToHorse(x)
{
	// Unless really close to the horse, better make sure to get there quickly.
	!SpatialDistanceVeryClose(x)	->	SpeedSprint;

	// The horse is walking and very close, so we can keep up by walking.
	SpatialWalking(x)				->	SpeedWalk;

	// The horse is jogging. Our jog speed is at least to being quick enough.
	SpatialJogging(x)				->	SpeedJog;

	// The horse is very close but sprinting or running.
	TRUE							->	SpeedSprint;
}

//-----------------------------------------------------------------------------
// Experimental squad stuff.

// Temporary squad program for when you don't want the squad formation
// to break up during combat.
program SquadMain
{
	!CombatRangeWeaponReadied && CanCombatReadyRangeWeapon->	CombatReadyRangeWeapon;
	TRUE															->	SquadUnalerted, SquadFire;
}


// Possibly temporary. This is a program for firing while keeping a squad formation.
program SquadFire
{
	WantToHurt(x) && CanCombatUseWeaponsAgainst(x)		->	CombatUseWeaponsAgainst(x);
}


program SquadUnalerted
{
	ObjectClassSquadMoveTo(x) && At(x)				->	Stay;
	// TODO: better choice of speed here:  move fast if under fire; slow if needing to stay quiet.
	ObjectClassSquadMoveTo(x) && CanMoveTowards(x)	->	MoveTowards(x), SpeedJog;	

//	TRUE		->	SquadFormSingleFile, SquadMatchSpeedToLeader, SquadLookAtLeader;
	TRUE		->	SquadFormUnorganized, SquadMatchSpeedToLeader, SquadLookAtLeader;
}


program SquadFormUnorganized
{
	SquadLeader(x) && !PositionKnownRecently(x) && CanFind(x)									->	Find(x);
	SquadLeader(x)																				->	SquadFollow(x);
	SquadLeader(x) && !KnowsWhereIs(x) && CanFind(x)											->	Find(x);
}


// PURPOSE:	This can be used by a squad to form a single file.
// NOTES:	Of interest to RDR2, I came across this definition:
//				"Indian file, single file; arrangement of persons in a row
//				following one after another, the usual way among Indians
//				of traversing woods, especially when on the war path."
//			Intended to be used in parallel with SquadMatchSpeedToLeader and
//			SquadLookAtLeader.
program SquadFormSingleFile
{
	SquadLeader(x) && !PositionKnownRecently(x) && CanFind(x)									->	Find(x);
	SquadMemberToFollow(x) && SpatialDirectionAheadOfMe(x) && SpatialMeBehindObject(x)			->	SquadFollow(x);
	SquadMemberToFollow(x) && SpatialDirectionAheadOfMe(x)										->	SquadFollow(x);
	SquadMemberToFollow(x) && SpatialMeBehindObject(x)											->	SquadFollow(x);
	SquadLeader(x) && !KnowsWhereIs(x) && CanFind(x)											->	Find(x);
}


// PURPOSE:	This program can be used by a squad member to match his movement
//			speed to that of the squad leader.
// NOTES:	This used to have rules duplicated with the ones in
//			FollowMatchSpeed(x), but there might not be a need for
//			that and I had to add rules. Branch again if necessary. /FF
program SquadMatchSpeedToLeader
{
	SquadLeader(x)	->	FollowMatchSpeed(x);
}


// PURPOSE:	Used by squad members to get them to look at their leader.
program SquadLookAtLeader
{
	SquadLeader(x) && CanHeadLookAt(x)			->	HeadLookAt(x);
}


// PURPOSE:	Used by a squad member to follow behind another squad member.
program SquadFollow(x)
{
	(SpatialMovingAwayFromMe(x) || !SquadMemberAt(x)) && CanMoveTowards(x)			->	MoveTowards(x);
	CanLookAt(x)																	->	LookAt(x), Stay;
	TRUE																			->	Stay;
}


// PURPOSE:	Rules about squads and their members.
rules Rules_Squad
{
	// <TITLE FollowedBySquadMember(x)>
	// PURPOSE:	True if x is followed by a member of our squad.
	// NOTES:	Does not check that x himself is a squad member.
	SquadMember(y)  && !SameObject(x, y) && SpatialLastObservedDirectionAheadOf(x, y) && SpatialLastObservedDirectionBehind(y, x) && SquadMemberClose(x, y)		->	FollowedBySquadMember(x);

	// <TITLE FollowingSquadMember(y)>
	// PURPOSE:	True if y is following a member of our squad.
	// NOTES:	Does not check that y himself is a squad member.
	SquadMember(x)  && !SameObject(x, y) && SpatialLastObservedDirectionAheadOf(x, y) && SpatialLastObservedDirectionBehind(y, x) && SquadMemberClose(x, y)		->	FollowingSquadMember(y);

	// <TITLE SquadMemberToFollow(y)>
	// PURPOSE:	Used to check if y is a squad member that's following somebody and that nobody else is following.
	((SquadMember(x) && FollowingSquadMember(x)) || SquadLeader(x)) && !FollowedBySquadMember(x)		->	SquadMemberToFollow(x);

	// <TITLE WantNotToHurt(x)>
	// PURPOSE:	If the squad is supposed to hold fire, forget about injuring anyone.
	InSquad AND NOT SquadAllowAttack													->	WantNotToHurt(x);

	// <TITLE CannotMoveTowards(x)>
	// PURPOSE:	If the squad is supposed to follow the leader, forget about going after anyone.
	InSquad AND ObjectClassSquadMoveTo(y) AND NOT SquadTargetClose(x, y)				->	CannotMoveTowards(x);
	InSquad AND NOT HasSquadTarget AND SquadLeader(y) AND NOT SquadTargetClose(x, y)	->	CannotMoveTowards(x);

	// <TITLE AimingAtMySquadLeader(x)>
	// PURPOSE:	Detect if actor x is aiming at our squad leader.
	CombatAimingAtWhenVisible(x, y) && SquadLeader(y) && WasVisibleRecently(x)			->	AimingAtMySquadLeader(x);

	// <TITLE AimedAtByMySquadLeader(x)>
	// PURPOSE:	Detect if our squad leader is aiming at actor x.  
	// Note:  we intentionally don't need to see our squad leader for this to be true.
	// Note:  for player squad leaders, this was set up (in code) to check their reticle component.
	CombatAimingAtWhenVisible(y, x) && SquadLeader(y)									->	AimedAtByMySquadLeader(x);

	// <TITLE FiringAtMySquadLeader(x)>
	// PURPOSE:	Detect if actor x has fired at our squad leader.
	CombatFiredAtVeryRecently(x, y) && SquadLeader(y) && WasVisibleRecently(x)			->	FiringAtMySquadLeader(x);

	// <TITLE FiredAtByMySquadLeader(x)>
	// PURPOSE:	Detect if our squad leader is firing at actor x.  
	// Note:  we intentionally don't need to see our squad leader for this to be true.
	CombatFiredAtVeryRecently(y, x) && SquadLeader(y)									->	FiredAtByMySquadLeader(x);

	// <TITLE AttackingMySquadLeader(x)>
	// PURPOSE:	Determine whether someone threatens the squad leader.
	AimingAtMySquadLeader(x) || FiringAtMySquadLeader(x)								->	AttackingMySquadLeader(x);

	// <TITLE AttackedByMySquadLeader(x)>
	// PURPOSE:	Determine whether the squad leader is attempting to kill someone.
	// AimedAtByMySquadLeader(x) || FiredAtByMySquadLeaderVeryRecently(x)					->	AttackedByMySquadLeader(x);

	// Adjustments to WantToHurt.  
	// NOTE:  intentionally not adjusting BaseWantToHurt.  The idea is that, when SquadAllowAttack is false,
	// the following rules specify the ONLY reasons why a squad member would ever want to hurt someone.
	
	// Defend self when attacked
	NOT SquadAllowAttack AND Enemy(x) AND (AimingAtMe(x) OR FiredAtMe(x))				->	WantToHurt(x) WITH 0.7;

	// Defend leader
	Enemy(x) AND AttackingMySquadLeader(x)												->	WantToHurt(x) WITH 0.7;

	// Attack leader's target
	Enemy(x) AND FiredAtByMySquadLeader(x)												->	WantToHurt(x) WITH 0.7;
	
	// 
	//Enemy(x) AND AimedAtByMySquadLeader(x)											->	WantToHurt(x) WITH 0.3;
}


debuggroup Squads
{
	filter SquadMember(x), predicate FollowedBySquadMember(x), label "FollowedBySquadMember $x";
	filter SquadMember(x), predicate FollowingSquadMember(x), label "FollowingSquadMember $x";
	filter SquadMember(x), predicate SquadAllowAttack, label "SquadAllowAttack $x";
	filter ObjectClassHuman(x), predicate AttackingMySquadLeader(x), label "AttackingMySquadLeader $x";
	filter ObjectClassHuman(x), predicate FiredAtByMySquadLeader(x), label "FiredAtByMySquadLeader $x";
	filter ObjectClassHuman(x), predicate AimedAtByMySquadLeader(x), label "AimedAtByMySquadLeader $x";
}

debuggroup WantToHurt
{
	filter ObjectClassHuman(x), predicate BaseWantToHurt(x), label "BaseWantToHurt $x";
	filter ObjectClassHuman(x), predicate WantToHurt(x), label "WantToHurt $x";
	filter ObjectClassHuman(x), predicate WantNotToHurt(x), label "WantNotToHurt $x";
	filter TRUE, predicate AttackOnSight, label "AttackOnSight";
}

//-----------------------------------------------------------------------------
// Stuff related to riding.

// Deal with preferences for riding rideables, or not.
// Goal:			!PrefersRiding && !PrefersWalking || PrefersRiding && Riding || PrefersWalking && !Riding
// Precondition:	none
program ResolveConveyancePrefs
{
	!PrefersRiding && !PrefersWalking											-> NIL;
	PrefersRiding && Riding														-> NIL;
	PrefersWalking && !Riding													-> NIL;
	PrefersRiding && CanMountNearbyHorse										-> MountNearbyHorse, SpeedJog;
	PrefersWalking && CanRideDismount											-> RideDismount;
}

// Mount a horse if one is nearby.
// Goal:			Riding
// Precondition:	CanMountNearbyHorse
program MountNearbyHorse
{
	// Check if goal achieved.
	Riding																		->	NIL;

	// Prefer horses that are very close.
	ObjectClassHorse(y) && SpatialDistanceVeryClose(y) && CanMoveToAndMount(y) && AllowedToRide(y)	->	MoveToAndMount(y);

	// Pick a horse that's further away if we have to. Note that some sort
	// of proximity is already included in the precondition.
	ObjectClassHorse(y) && CanMoveToAndMount(y) && AllowedToRide(y)									->	MoveToAndMount(y);
}


// Move to a specific horse and mount it.
// Goal:			RidingOn(x)
// Precondition:	CanMoveToAndMount(x)
program MoveToAndMount(x)
{
	At(x) && CanRideMount(x)					->	RideMount(x);

	// TODO: Think about the At(x) && !CanRideMount(x) case

	TRUE										->	FindAndMoveTowards(x);
}


// Rules related to riding.
rules Rules_Riding
{
	// Precondition for MountNearbyHorse.
	// Note that this checks AllowedToRide(x), to not mount horses that the
	// designers want to reserve for the player.
	Riding || (ObjectClassHorse(x) && CanMoveToAndMount(x) && SpatialDistanceClose(x) && AllowedToRide(x))			->	CanMountNearbyHorse;

	// Precondition for MoveToAndMount(x).
	// Note that this does NOT include AllowedToRide(x), since we want to be
	// able to use this action to mount a horse targeted by TASK_MOUNT() even
	// if that horse is otherwise reserved.
	ObjectClassRideable(x) && !HasRider(x) && (At(x) && CanRideMount(x) || CanFindAndMoveTowards(x))	->	CanMoveToAndMount(x);
}


// Debug group.
debuggroup Riding
{
	filter TRUE, predicate CanMountNearbyHorse, label "CanMountNearbyHorse";
	filter TRUE, predicate ObjectClassHorse(x), label "Horse $x";
	filter TRUE, predicate Riding, label "Riding";
	filter TRUE, predicate RidingVehicle, label "Riding vehicle";
	filter TRUE, predicate PrefersRiding, label "Prefers riding";
	filter TRUE, predicate PrefersWalking, label "Prefers walking";
	filter ObjectClassHorse(x), predicate RidingOn(x), label "Riding on $x";
	filter ObjectClassVehicle(x), predicate RidingOnVehicle(x), label "Riding on vehicle $x";
	filter ObjectClassRideable(x), predicate ObjectClassRideable(x), label "$x rideable";
	filter ObjectClassHuman(x), predicate Riding(x), label "$x riding";
	filter ObjectClassHuman(x), predicate RidingVehicle(x), label "$x riding vehicle";
	filter ObjectClassHuman(x) && ObjectClassHorse(y), predicate RidingOn(x, y), label "$x riding on $y";
	filter ObjectClassHuman(x) && ObjectClassVehicle(y), predicate RidingOnVehicle(x, y), label "$x riding on vehicle $y";
	filter ObjectClassRideable(x), predicate AllowedToRide(x), label "Allowed to ride $x";
}

//-----------------------------------------------------------------------------
// Stuff related to scripted tasks.

// Try to perform various scripted "goals" in parallel to other
// activities. Currently only used for looking at stuff. /FF
program PerformExternalGoals
{
	TRUE		->	PerformExternalGoalLookAt;
}

// Look at positions or actors that this actor has been scripted to look at.
// Note that this is currently not an actual task, but something that can
// be done in parallel to carrying out tasks. /FF
program PerformExternalGoalLookAt
{
	ObjectClassObjectiveLookAt(x) && CanLookAt(x)	->	LookAt(x) WITH 2.0;	// Wonder if this strength is enough to override other uses? /FF
}

program PerformTaskActionWithoutTarget
{
	TRUE && CanActionPerform											->	ActionPerform;
}

program PerformTaskActionWithTarget(x)
{
	At(x) && (SpatialLastObservedFacingSameDirection(x) || !ObjectClassLocation(x)) && CanActionPerform(x)	->	ActionPerform(x);
	At(x) && ObjectClassLocation(x) && CanFaceInSameDirection(x)											->	FaceInSameDirection(x);
	CanMoveTowards(x) /* should be part of precondition? */													->	MoveTowards(x);
}

// TODO: Clean this up a bit. Implemented while short on time.
program PerformTaskMove
{
	// If ordered to follow somebody, do so if possible.
	ObjectClassObjectiveFollow(x) && CanFindAndFollow(x)							->	FindAndFollow(x);

	// Used for TASK_FOLLOW_PATH command.
	HasPathToFollow && CanMoveFollowPath											->	MoveFollowPath, ExternalMatchSpeed;

	// Used for TASK_FLEE_ACTOR.
	ObjectClassObjectiveRetreatFrom(x) && CanMoveRetreatFrom(x)						->	MoveRetreatFrom(x):(SpeechEvent("DisallowShootAndFace")) /*:(SpeechEvent("Retreating"))*/, SpeedSprint;

	// Used for TASK_GO_TO_COORD script command.
	ObjectClassLocation(x) && ObjectClassObjectiveMoveTo(x) && !At(x) && CanMoveTowards(x)	->	MoveTowards(x):(SpeechEvent("DisallowShootAndFace")), ExternalMatchSpeed;

	// Used for TASK_GO_TO_COORD script command.
	ObjectClassLocation(x) && ObjectClassObjectiveMoveTo(x) && At(x)				->	Stay;
}


// TODO: Clean this up a bit. Implemented while short on time.
program PerformTaskDestroyWhileMoving
{
	CombatRangeWeaponReadied && ObjectClassObjectiveDestroy(x)							->	CombatShootNoCoverB(x), CombatShootNoCoverC(x);
	!CombatRangeWeaponReadied && CanCombatReadyRangeWeapon						->	CombatReadyRangeWeapon;
}


// TODO: Clean this up a bit. Implemented while short on time.
program PerformTaskDestroy
{
	HasMoveObjective		->	PerformTaskDestroyWhileMoving;
	!HasMoveObjective && ObjectClassObjectiveDestroy(x) && CanCombatSearchAndAttack(x) && (Alive(x) || ObjectClassLocation(x))				->	CombatSearchAndAttack(x);
}


// Used by TASK_USE_GRINGO script command.
program PerformTaskMoveToAndUseHotspot
{
	CanHotspotUseExternal				->	HotspotUseExternal;
	TRUE /*CanHotspotMoveToExternal*/	->	HotspotMoveToExternal;
}


// Used for TASK_USE_TURRET script command.
// TODO: Certainly this will need some cleanup.
// Also, at the moment the task never ends, so the detach can never happen.
program PerformTaskUseTurret(x)
{
	!HasTurretObjective(x)								-> TurretDetach;
	MyTurret(x) AND WantToHurt(y) AND CanCombatUseWeaponsAgainst(y) -> CombatUseWeaponsAgainst(y);
	MyTurret(x)											-> Stay;
	At(x) AND !MyTurret(x) AND 
		CombatWeaponDrawn AND CanCombatWeaponHolster	-> CombatWeaponHolster;
	At(x) /*AND CanTurretAttach(x)*/					-> TurretAttach(x);
	CanMoveTowards(x)				-> MoveTowards(x), SpeedJog;
}


program PerformTaskMount
{
	Riding													-> NIL;
	ObjectClassObjectiveMount(x) && CanMoveToAndMount(x)	-> MoveToAndMount(x), SpeedJog;
}


program PerformTaskDismount
{
	NOT Riding												-> NIL;
	HasDismountObjective AND CanRideDismount				-> RideDismount;
}


// Debug group.
debuggroup Turret
{
	filter ObjectClassHuman(x), predicate WantToHurt(x), label "WantToHurt $x";
	filter TRUE, predicate HasTurret, label "HasTurret";
	filter ObjectClassTurret(x), predicate 	MyTurret(x), label "MyTurret $x";
	filter ObjectClassTurret(x), predicate 	HasTurretObjective(x), label "HasTurretObjective $x";
	filter ObjectClassTurret(x), predicate 	PropInUse(x), label "HasTurretObjective $x";
}


// Debug group for tasks
debuggroup Task
{
	filter TRUE, predicate HasMountObjective, label "HasMountObjective";
	filter TRUE, predicate HasDismountObjective, label "HasDismountObjective";
}


// This program executes the TASK_SHOOT_ENEMIES_FROM_POSITION. It's basically autonomous
// shooting coupled with movement to a particular location (x), but with some extra
// details regarding face direction, weapon draw/load, etc.
program PerformTaskShootFrom(x)
{
	// If we're in place, have a target, and can use weapons right now, proceed with that while facing the
	// target. The WantToHurt(y) && CanCombatUseWeaponsAgainst(y) part is basically what AutonomousFire
	// would've done, we're just adding the facing here.
	At(x) && WantToHurt(y) && CanCombatUseWeaponsAgainst(y)		->	Face(y), CombatUseWeaponsAgainst(y), Stay;

	// If we're in position but don't have a loaded weapon, load/draw it. AutonomousFire would do
	// that automatically, but in this rule, as opposed to the next, we don't face any particular
	// direction. This means that if we're firing at a target and run out of ammo, we will not
	// turn back to the direction of the point while we reload.
	// Note: (CombatRangeWeaponReadied || CanCombatReadyRangeWeapon) are a part of the
	// precondition, so !CombatRangeWeaponReadied -> implies CombatReadyRangeWeapon
	// (at least assuming no fuzziness here).
	At(x) && !CombatRangeWeaponReadied 
		/*&& CanCombatReadyRangeWeapon*/					->	CombatReadyRangeWeapon, Stay;

	// I added these to address a problem that I observed after Chris P. reported
	// some weirdness. Basically, make sure that we look at recent/nearby enemies even
	// if we can't shoot them right now, rather than facing the scripted direction.  /FF
	At(x) && WantToHurt(y) && SpatialDistanceVeryClose(y) && CanLookAt(y)		->	LookAt(y), Stay;
	At(x) && WantToHurt(y) && SpatialDistanceClose(y) && CanLookAt(y)			->	LookAt(y), Stay;


	// We're in position but don't seem to have any particular target, stay here and
	// face in the desired direction.
	// TODO: Replace LookAround by some sort of look-for-enemies program, which can
	// be more intelligent in looking at unidentified actors etc.
	At(x) && CanFaceInSameDirection(x) && CanLookAround			->	Stay, FaceInSameDirection(x), LookAround;
	At(x) && CanFaceInSameDirection(x)							->	Stay, FaceInSameDirection(x);

	// We're in position, but can't face in a particular direction. This probably
	// just means that x doesn't have any directional information.
	// TODO: Replace LookAround by some sort of look-for-enemies program. Unlike in the previous
	// case where we've got a face direction, we wouldn't mind if this one turned the whole
	// body to cover 360 degrees.
	At(x) && CanLookAround										->	Stay, LookAround;
	At(x)														->	Stay;

	// We are not at the position, but we've got the weapon drawn. Jog towards our
	// desired shooting location and fire at will.
	// Note that CanMoveTowards(x) is implied from the precondition and !At(x).
	/*CanMoveTowards(x) && */ CombatRangeWeaponReadied										->	MoveTowards(x), SpeedJog, AutonomousFire;

	// We are not in position and we don't have a drawn/loaded weapon, move towards
	// the destination and draw/load. Note that this and the previous rule couldn't
	// simply be replaced to use AutonomousFire, because of the subtle difference that
	// now we draw/load our gun even if we don't know of any target.
	// Also note that CanMoveTowards(x) && CanCombatReadyRangeWeapon are implied by
	// the precondition and previous rules.
	//CanMoveTowards(x) && !CombatRangeWeaponReadied && CanCombatReadyRangeWeapon		->	MoveTowards(x), SpeedJog, CombatReadyRangeWeapon;
	TRUE																						->	MoveTowards(x), SpeedJog, CombatReadyRangeWeapon;
}


// PURPOSE:	Carry out tasks involving a specific cover location, by first moving there and then hiding or shooting from there
//			depending on what the task was.
// TODO:	Work a bit more on this, add preconditions and stuff. /FF
program PerformTaskUseCover
{
	// If not scripted to only hide, once we are at the cover location try to destroy specific targets.
	!CombatCoverExternalHide && CombatAtCoverExternal && ObjectClassObjectiveDestroy(x) && CanCombatUseWeaponsAgainstFromCover(x)	->	CombatUseWeaponsAgainstFromCover(x);

	// If not scripted to only hide, once we are at the cover location try to destroy enemy targets.
	!CombatCoverExternalHide && CombatAtCoverExternal && WantToHurt(x) && CanCombatUseWeaponsAgainstFromCover(x)					->	CombatUseWeaponsAgainstFromCover(x);

	// If not scripted to only hide (but no valid enemies were found), try to peek from cover and wait for those enemies to arrive.
	!CombatCoverExternalHide && CombatAtCoverExternal && CanCombatPeekFromCover														->	CombatPeekFromCover;

	// If at cover and none of the above applied, hide. This would be the typical case when TASK_HIDE_AT_COVER was used.
	CombatAtCoverExternal && CanCombatHideAtCover																					->	CombatHideAtCover;

	// If not at the desired cover location, move there and try to eliminate scripted targets.
	CanCombatMoveToCoverExternal && HasDestroyObjective																				->	PerformTaskDestroyWhileMoving, CombatMoveToCoverExternal;

	// TODO: Maybe there should be a rule here for autonomous firing at non-scripted targets while moving to cover? /FF

	// Move to the desired cover location.
	CanCombatMoveToCoverExternal																									->	CombatMoveToCoverExternal;
}


// This program performs the current task, whatever it is. This used to be much
// more distributed, but doing it this way allows us to use any priority for
// any task.
// Precondition:	CanPerformTask
program PerformTask
{
	// Move to and then hide at or shoot from a specific location, for TASK_SHOOT_FROM_COVER etc.
	HasCombatCoverUseObjective												->	PerformTaskUseCover;

	HasActionObjectiveWithoutTarget											->	PerformTaskActionWithoutTarget;
	HasActionObjectiveWithTarget && ObjectClassObjectivePerformActionOn(x)	->	PerformTaskActionWithTarget(x);

	ObjectClassObjectiveSeekCoverFrom(x) && CanStayAwayFromDanger(x)		->	StayAwayFromDanger(x);

	// This is for TASK_USE_GRINGO.
	HasHotspotUseObjective && CanPerformTaskMoveToAndUseHotspot				->	PerformTaskMoveToAndUseHotspot;

	ObjectClassObjectiveShootFrom(x) && CanPerformTaskShootFrom(x)			->	PerformTaskShootFrom(x);

	MyTurret(x) OR CanFulfillTurretObjective(x)		->	PerformTaskUseTurret(x);
	HasDismountObjective							->	PerformTaskDismount;
	HasMountObjective								->	PerformTaskMount;
	HasMoveObjective && HasDestroyObjective			->	PerformTaskMove, PerformTaskDestroy;
	HasMoveObjective								->	PerformTaskMove, AutonomousFireIfAllowed;
	HasDestroyObjective								->	PerformTaskDestroy;
	ObjectClassObjectiveFace(x)	&& CanFace(x)		->	FaceAnimated(x);

	// If we're at a position we are supposed to guard, stand guard at the position.
	ObjectClassObjectiveGuard(x) && At(x) && CanGuard(x)							->	Guard(x);

	// If we are close to a position we are supposed to guard, walk towards it.
	ObjectClassObjectiveGuard(x) && SpatialDistanceClose(x) && CanMoveTowards(x)	->	MoveTowards(x), SpeedWalk;

	// If we are far away from a position we are supposed to guard, jog towards it.
	ObjectClassObjectiveGuard(x) && CanMoveTowards(x)								->	MoveTowards(x), SpeedJog;

	// If we're set up to patrol, walk along the patrol path.
	HasPatrolPath										->	Patrol:(SpeechEvent("AudioEventPatrol")), SpeedWalk;

	// HACK: Future Activity #0 = idle
	ObjectiveWander && CanMoveWander					->	MoveWander, PlanActivity(0, 5.0, 7.0), PrepareForActivity(0);

	HasCrouchObjective							->	Stay, PostureCrouch, AutonomousFireIfAllowed;

	HasSimpleTask								->	PerformSimpleTask, AutonomousFireIfAllowed;
	
	// This is a bit odd, as TASK_STAND_STILL does not result in any particular
	// predicate value, just a lack of other things to do. Because of this the
	// user of PerformTask will need to use the external priority to determine
	// whether to call PerformTask or not.
	// - Not quite true anymore, since there is a HasTask predicate now. /FF
	TRUE												->	Stay, AutonomousFireIfAllowed;
}

program AutonomousFireIfAllowed
{
	!DisallowShootAndFace		->	AutonomousFire;
}

// A simple program for firing autonomously while some other program 
// dictates the character's movement.
program AutonomousFire
{
	WantToHurt(x) && !CombatRangeWeaponReadied 
		&& CanCombatReadyRangeWeapon			->	CombatReadyRangeWeapon, LookAtIfPossible(x);

	WantToHurt(x) && CanCombatUseWeaponsAgainst(x)				->	CombatUseWeaponsAgainst(x);
	WantToHurt(x) && SpatialDistanceClose(x) && CanLookAt(x) && PositionKnownVeryRecently(x)	->	LookAt(x);
}


rules Preconditions_External
{
	ObjectClassObjectiveDestroy(x)								->	HasDestroyObjective;

	HasCombatCoverUseObjective									->	HasMoveObjective;
	ObjectClassLocation(x) && ObjectClassObjectiveMoveTo(x)		->	HasMoveObjective;
	HasPathToFollow												->	HasMoveObjective;
	ObjectClassObjectiveFollow(x)								->	HasMoveObjective;
	ObjectClassObjectiveRetreatFrom(x)							->	HasMoveObjective;
	ObjectClassObjectiveMount(x)								->	HasMountObjective;

	// For TASK_USE_GRINGO.
	CanHotspotUseExternal || CanHotspotMoveToExternal			->	CanPerformTaskMoveToAndUseHotspot;

	ObjectClassTurret(x) AND ObjectClassObjectiveMoveTo(x)		->	DesiredTurret(x);

	MyTurret(x) OR (DesiredTurret(x) AND NOT PropInUse(x))		->	CanFulfillTurretObjective(x), CanFulfillTurretObjective, HasMoveObjective;

	MyTurret(x) OR DesiredTurret(x)								->	HasTurretObjective(x), HasTurretObjective;

	// To shoot from a position, we need to be able to get to the position, and we need to be able to shoot.
	(At(x) || CanMoveTowards(x)) && (CombatRangeWeaponReadied || CanCombatReadyRangeWeapon)	->	CanPerformTaskShootFrom(x);

/*
	(ObjectClassObjectiveFollow(x) && CanFindAndFollow(x))
	|| (ObjectClassLocation(x) && ObjectClassObjectiveMoveTo(x) && At(x))
	|| (ObjectClassLocation(x) && ObjectClassObjectiveMoveTo(x) && CanMoveTowards(x))
	|| (ObjectClassObjectiveGuard(x) && At(x) && CanGuard(x))
	|| (ObjectClassObjectiveGuard(x) && SpatialDistanceClose(x) && CanMoveTowards(x))
	|| (ObjectClassObjectiveGuard(x) && CanMoveTowards(x))
	|| (ObjectClassObjectiveDestroy(x) && CanCombatSearchAndAttack(x) && Alive(x))
	|| HasPatrolPath
	|| TRUE	// TASK_STAND_STILL: TODO?
	->	CanPerformTask;
*/
	// The priority should be set if and only if we currently have a task.
	// If we had something that indicate that a TASK_STAND_STILL is in
	// progress, the precondition should be something like the disabled but
	// awkward expression above this - in that case, maybe a new language
	// feature would be in order. /FF
//	ExternalPriorityHighest || ExternalPriorityCombat || ExternalPriorityUnalerted	->	CanPerformTask;
	HasTask && (ExternalPriorityHighest || ExternalPriorityCombat || ExternalPriorityUnalerted || ExternalPriorityDefaultBehavior) &&
		(!HasTurretObjective || CanFulfillTurretObjective) ->	CanPerformTask;
}


debuggroup HotspotsAmbient
{
	filter TRUE, predicate CanHotspotMoveTo,					label "CanHotspotMoveTo";
	filter TRUE, predicate CanHotspotUse,						label "CanHotspotUse";
}


debuggroup HotspotsTasked
{
	filter TRUE, predicate HasHotspotUseObjective,				label "HasHotspotUseObjective";
	filter TRUE, predicate CanPerformTaskMoveToAndUseHotspot,	label "CanPerformTaskMoveToAndUseHotspot";
	filter TRUE, predicate CanHotspotMoveToExternal,			label "CanHotspotMoveToExternal";
	filter TRUE, predicate CanHotspotUseExternal,				label "CanHotspotUseExternal";
}


debuggroup ExternalPriorities
{
	filter TRUE, predicate ExternalPriorityHighest, label "Priority Highest";
	filter TRUE, predicate ExternalPriorityCombat, label "Priority Combat";
	filter TRUE, predicate ExternalPriorityUnalerted, label "Priority Unalerted";
	filter TRUE, predicate ExternalPriorityDefaultBehavior, label "Priority Default Behavior";
}


// This tries to match the actor's speed of movement with what's externally
// requested through aiMemoryExternal. Certain script commands will need this
// to work properly.
program ExternalMatchSpeed
{
	ExternalMoveTypeSprint		->	SpeedSprint;
	ExternalMoveTypeRun			->	SpeedRun;
	ExternalMoveTypeJog			->	SpeedJog;
	ExternalMoveTypeWalk		->	SpeedWalk;
}

//-----------------------------------------------------------------------------
// Rules and programs mainly related to civilians avoiding danger that doesn't
// directly concern them, such as some guy firing his weapon at nobody or at
// somebody else.

// Stay away from x. The primary use for this is for a civilian to
// escape some dangerous situation that they have no reason to get
// involved in, for example a gunfight unrelated to them.
// Currently this basically includes seeking cover to protect from x, looking
// at x if close, and retreating if no good cover can be found.
// Precondition:	CanStayAwayFromDanger(x)
program StayAwayFromDanger(x)
{
	TRUE	->	StayAwayFromDangerMove(x), CombatSeekCoverToProtectFrom(x), StayAwayFromDangerLook(x);
}


// Subprogram used by StayAwayFromDanger(x) to look at the
// dangerous object if it's close.
// Precondition:	none at the moment, it's intended to always be usable and
//					typically executed in parallel with other programs.
program StayAwayFromDangerLook(x)
{
	// If x is very close, look at it. This primary uses head movement,
	// though if nothing else is going on LookAt(x) can probably make
	// the actor turn as well.
	SpatialDistanceVeryClose(x) && CanLookAt(x)			->	LookAt(x);
}


// Subprogram used by StayAwayFromDanger(x) taking care of the movement part.
// It currently involves getting behind cover if available, or retreating.
// Precondition:	CanStayAwayFromDangerMove(x)
program StayAwayFromDangerMove(x)
{
	// If we can get behind cover (incl. staying at cover you're already at),
	// do so. StayAwayFromDangerMoveGetBehindCover controls if it's
	// worthwhile to stay behind cover or if a new cover location should
	// be found instead.
	CanGetBehindCover && StayAwayFromDangerMoveGetBehindCover(x)	->	GetBehindCover;

	// Retreat if possible, if we could not find cover.
	AllowBehaviorRetreat && CanMoveRetreatFrom(x)
		->	MoveRetreatFrom(x):(SpeechEvent("Retreating"), SpeechEvent("DisallowShootAndFace")),
			DodgeWhileRetreatingFrom(x), 
			SpeedSprint;

	// TODO: Maybe cower here, without moving?

	// Note: please remember to update the precondition if you add or change something.
}


rules StayAwayFromDangerRules
{
	// CivilianDanger(x) is true for objects that may be of danger to us
	// so that we should stay away from them.
	// TODO: Expand on this.
	// TODO: Make the times involved here tunable.
	FiredSomewhatRecently(x)						->	CivilianDanger(x);

	// The main purpose of this is to simplify CanStayAwayFromDangerMove(x), to
	// not have to duplicate the whole expression.
	(!InjuredWhileAtThisNoGoodCover) && ((!CombatAtCover) || CombatAtCoverGood || (!SpatialDistanceClose(x) ))	->	StayAwayFromDangerMoveGetBehindCover(x);

	// Precondition for StayAwayFromDangerMove(x).
	CanMoveRetreatFrom(x) || (CanGetBehindCover && StayAwayFromDangerMoveGetBehindCover(x))					->	CanStayAwayFromDangerMove(x);

	// Precondition for StayAwayFromDanger(x). Only the movement part is crucial
	// for the program to have a useful effect.
	CanStayAwayFromDangerMove(x)					->	CanStayAwayFromDanger(x);
}


debuggroup Civilians
{
	filter ObjectClassCreature(x), predicate FiredSomewhatRecently(x), label "$x fired recently";
	filter ObjectClassCreature(x), predicate CanMoveRetreatFrom(x), label "Can retreat from $x";
	filter TRUE, predicate CombatAtCover, label "At cover";
	filter TRUE, predicate CombatAtCoverGood, label "At good cover";
	filter TRUE, predicate InjuredWhileAtThisNoGoodCover, label "Injured at no good cover";
	filter HasBeenHitByProjectile(x), predicate HitByProjectileRecently(x), label "$x hit by projectile recently";
}

//-----------------------------------------------------------------------------
// Dodging-related programs, rules and debug groups 

debuggroup Dodging
{
	filter TRUE,			predicate CanDodge,								label "CanDodge";
	filter TRUE,			predicate CanDodgeWhileAttacking,				label "CanDodgeWhileAttacking";
	filter TRUE,			predicate CanDodgeWhileRetreating,				label "CanDodgeWhileRetreating";
	filter TRUE,			predicate EventActive("Retreating"),			label "Retreating";
	filter TRUE,			predicate EventActive("MovingToCover"),			label "MovingToCover";
	filter TRUE,			predicate DodgedTooRecently,					label "DodgedTooRecently";
	filter TRUE,			predicate DamagedRecently,						label "DamagedRecently";
	filter TRUE,			predicate MovementClearLeftOfMe,				label "MovementClearLeftOfMe";
	filter TRUE,			predicate MovementClearRightOfMe,				label "MovementClearRightOfMe";
	filter TRUE,			predicate MovementClearAheadOfMe,				label "MovementClearAheadOfMe";
	filter Player(x),		predicate FiredAtMe(x),							label "FiredAtMe";
	filter Player(x),		predicate AimingAtMe(x),						label "AimingAtMe";
	filter Player(x),		predicate FiredVeryRecently(x),					label "FiredVeryRecently";
	filter Player(x),		predicate ShouldDodgeAttacker(x),				label "ShouldDodgeAttacker";
	filter Player(x),		predicate ShouldDodgeWhileRetreatingFrom(x),	label "ShouldDodgeWhileRetreatingFrom";
	filter Player(x),		predicate SpatialDirectionAheadOfMe(x),			label "AheadOfMe";
	filter Player(x),		predicate SpatialDirBoolLeftOfMe(x),			label "LeftOfMe";
	filter Player(x),		predicate SpatialDirBoolRightOfMe(x),			label "RightOfMe";
	
	filter Player(x),		predicate SpatialLastObservedDirectionBehindMe(x),	label "LastObservedBehindMe";
	filter NewProjectileImpact(x),	predicate SpatialDistanceVeryClose(x),	label "CloseProjectileImpact";
	filter ShouldDodgeImpact(x),	predicate ShouldDodgeImpact(x),			label "ShouldDodgeImpact";
}


rules DodgeWhenUnderFireRules
{
	// Must be an elite (or otherwise allowed via combaat class) to dodge.
	// Can't dodge too often, or if at cover.
	CombatClassDodgeWhenUnderFire AND !DodgedTooRecently		->	CanDodge;

	EventActive("MovingToCover") OR EventActive("Retreating")	->  RunningAway;

	CombatClassDodgeWhenUnderFire AND !CombatAtCover			->	CanDoSimpleEliteMovement;


	// Must be an elite (or otherwise allowed via combaat class) to dodge.
	// Can't dodge too often, or if at cover.
	CanDodge AND !RunningAway AND !CombatAtCover				->	CanDodgeWhileAttacking;

	CanDodge AND RunningAway AND !CombatAtCover					->	CanDodgeWhileRetreating;

	SpatialDirectionAheadOfMe(x) 
		AND (FiredAtMe(x) OR AimingAtMe(x)) 
		AND FiredVeryRecently(x)								->	ShouldDodgeAttacker(x);

	SpatialLastObservedDirectionBehindMe(x) 
		AND (FiredAtMe(x) OR AimingAtMe(x)) 
		AND FiredVeryRecently(x)								->	ShouldDodgeWhileRetreatingFrom(x);
	
	!DamagedRecently &&		
		NewProjectileImpact(x) && SpatialDistanceClose(x)		->	ShouldDodgeImpact(x);	
}

program DodgeImpacts
{
	!CanDodgeWhileAttacking							->	NIL;
	
	// Perform a dodge.  Note that this will always result in some dodging
	// happening, so we must be sure that we want to dodge by this point.
	// And anything that ought to happen each time we perform a dodge can happen
	// in parallel here.
	ShouldDodgeImpact(x)							->	DodgeAwayFrom(x) WITH 2.0;
}

program SimpleEliteMovement(x)
{
	!CanDoSimpleEliteMovement			->	NIL;
	TRUE								->	GoLeftIfClear(x), GoRightIfClear(x);
}

program GoLeftIfClear(x)
{
	SpatialDirBoolRightOfMe(x)
		AND (AimingAtMe(x) OR (FiredAtMe(x) AND FiredVeryRecently(x)))
		AND MovementClearLeftOfMe				->	SpeedJog, MoveDirectional(2) WITH 1.7;
}

program GoRightIfClear(x)
{
	SpatialDirBoolLeftOfMe(x) 
		AND (AimingAtMe(x) OR (FiredAtMe(x) AND FiredVeryRecently(x)))
		AND MovementClearRightOfMe				->	SpeedJog, MoveDirectional(3) WITH 1.7;
}


// For considering dodging from anyone/anything while retreating
program DodgeWhileRetreating
{
	!CanDodgeWhileRetreating						->	NIL;
	
	// Perform a dodge.  Note that this will always result in some dodging
	// happening, so we must be sure that we want to dodge by this point.
	// And anything that ought to happen each time we perform a dodge can happen
	// in parallel here.
	ShouldDodgeWhileRetreatingFrom(x)
		AND MovementClearAheadOfMe					->	Dodge("DIVE_F") WITH 5.0;
}

// For considering dodging a particular actor while retreating from them.
program DodgeWhileRetreatingFrom(x)
{
	!CanDodgeWhileRetreating						->	NIL;
	
	// Perform a dodge.  Note that this will always result in some dodging
	// happening, so we must be sure that we want to dodge by this point.
	// And anything that ought to happen each time we perform a dodge can happen
	// in parallel here.
	ShouldDodgeWhileRetreatingFrom(x)
		AND MovementClearAheadOfMe					->	Dodge("DIVE_F") WITH 5.0;
}



// For considering dodging a particular actor
program DodgeWhenAttackedBy(x)
{
	!CanDodgeWhileAttacking							->	NIL;
	
	// Perform a dodge.  Note that this will always result in some dodging
	// happening, so we must be sure that we want to dodge by this point.
	// And anything that ought to happen each time we perform a dodge can happen
	// in parallel here.
	ShouldDodgeAttacker(x)							->	DodgeAwayFrom(x);
}


program DodgeAwayFrom(x)
{
	// Dive-rolls.  The huge action strength is because the value of
	// SpatialDistanceExtremelyClose will most likely be very very low.
	SpatialDistanceExtremelyClose(x) 
		AND SpatialDirBoolLeftOfMe(x)
		AND MovementClearRightOfMe			->	Dodge("DIVE_R") WITH 250.0;
	SpatialDistanceExtremelyClose(x)
		AND SpatialDirBoolRightOfMe(x)
		AND MovementClearLeftOfMe			->	Dodge("DIVE_L") WITH 250.0;
	
	// Dodge ("sidestep").  Again, the huge action strength is because 
	// the value of SpatialDistanceExtremelyClose will most likely be very low.
	//
	// NOTE: The "_L" and "_R" sense seems backwards here, but produces the 
	// right results.  That's probably because it's also backwards in Dr. V.
	// TODO:  check that out and flip in both places.
	SpatialDirBoolLeftOfMe(x)	
		AND MovementClearRightOfMe			->	Dodge("DODGE_L") WITH 250.0;
	SpatialDirBoolRightOfMe(x)
		AND MovementClearLeftOfMe			->	Dodge("DODGE_R") WITH 250.0;
	
	// We should always know whether to go left or right -- but 
	// in case we don't, the default is to go in our current
	// direction of motion.
	MovementClearLeftOfMe AND MovementClearRightOfMe	->	Dodge("DODGE") WITH 1.8;
}

// End of dodging stuff
//-----------------------------------------------------------------------------
