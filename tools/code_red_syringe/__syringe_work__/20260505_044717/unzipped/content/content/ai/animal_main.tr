debuggroup Animal_Horse_Stay_Still
{
	filter TRUE, predicate AnimalShouldStandStillForRider, label "AnimalShouldStandStillForRider";
	filter TRUE, predicate AnimalTuningEventDisMountedWithinStandBeforeWanderTime, label "AnimalTuningEventDisMountedWithinStandBeforeWanderTime";
	filter TRUE, predicate PerformSimpleTask_0SomewhatRecently, label "PerformSimpleTask_0SomewhatRecently";
	filter TRUE, predicate AnimalToldToStayStillRecently, label "AnimalToldToStayStillRecently";
}

debuggroup Animal_Pack_flee
{
	filter TRUE, predicate AnimalFleeGunshotsRatio, label "AnimalFleeGunshotsRatio";
	filter TRUE, predicate AnimalOutnumbered, label "AnimalOutnumbered";


	
	filter Player(x), predicate CanAnimalFlee(x), label "CanAnimalFlee $x";
	
// filter CanAnimalFlee(x), predicate FlockFleeDeadFlockMembers, label "FlockFleeDeadFlockMembers";
	filter CanAnimalFlee(x), predicate AnimalOfMySpecies(x), label "AnimalOfMySpecies $x";
	filter !Alive(x), predicate AnimalOfMySpecies(x), label "Not Alive $x";
}

debuggroup Animal_Startle_reaction
{
	filter TRUE, predicate AnimalCanStartle, label "AnimalCanStartle";
	filter TRUE, predicate NewLoudNoise(x), label "NewLoudNoise $x";
	filter TRUE, predicate NewProjectileImpact(x), label "NewProjectileImpact $x";	

	filter RecentLoudNoise(x), predicate AnimalCanStartleNoise(x), label "AnimalCanStartleNoise LoudNoise $x";
	filter RecentProjectileImpact(x), predicate AnimalCanStartleNoise(x), label "AnimalCanStartleNoise Projectile $x";
	
	filter !Alive(x), predicate SpatialDistanceVeryClose(x), label "dead body close $x";	
	filter !Alive(x), predicate AnimalOfMySpecies(x), label "dead body AnimalOfMySpecies $x";	

	/*filter TRUE, predicate AnybodyFiredRecently, label "AnybodyFiredRecently";
	filter TRUE, predicate NewLoudNoise(x), label "NewLoudNoise $x";
	filter TRUE, predicate NewProjectileImpact(x), label "NewProjectileImpact $x";

	filter TRUE, predicate RecentLoudNoise(x), label "RecentLoudNoise $x";
	filter RecentLoudNoise(x), predicate RecentLoudNoiseExclude(x), label "RecentLoudNoiseExclude $x";
	filter RecentLoudNoise(x), predicate NoRecentLoudNoiseExcluding(x), label "NoRecentLoudNoiseExcluding $x";

	filter TRUE, predicate RecentProjectileImpact(x), label "RecentProjectileImpact $x";	
	filter RecentProjectileImpact(x), predicate RecentProjectileImpactExclude(x), label "RecentProjectileImpactExclude $x";	
	filter RecentProjectileImpact(x), predicate NoRecentProjectileImpactExcluding(x), label "NoRecentProjectileImpactExcluding $x";	
	
	filter RecentLoudNoise(x), predicate NoRecentGunSoundsExcluding(x), label "NoRecentGunSoundsExcluding $x";	
	filter RecentProjectileImpact(x), predicate NoRecentGunSoundsExcluding(x), label "NoRecentGunSoundsExcluding $x";
	*/
}

debuggroup Animal_Ranch01_debbugging
{
	filter TRUE, predicate AnimalTuningAllowGrabPrey, label "AnimalTuningAllowGrabPrey";
	filter SpatialDistanceVeryClose(x), predicate CanAnimalAttackGrab(x), label "CanAnimalAttackGrab $x";
	filter CanAnimalAttackGrab(x), predicate CanAnimalGrab(x), label "CanAnimalGrab $x";
	filter TRUE, predicate AnimalHasGrabbedObject, label "AnimalHasGrabbedObject";	
}

debuggroup Animal_Fire_Reactions
{
	filter TRUE, predicate FireVolumeClose, label "FireVolumeClose";
	filter TRUE, predicate FireVolumeVeryClose, label "FireVolumeVeryClose";
}



