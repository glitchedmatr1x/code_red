+static Vector3 companionPointInFront(const Vector3& playerPos, float heading, float distance, float yOffset) {
+    // RDR PC positions observed in logs use X/Z as the ground plane and Y as height.
+    // Older build incorrectly moved on X/Y, which can place the clone above/below the player
+    // instead of visibly in front. Keep Y as vertical height and move forward on X/Z.
+    float rad = heading * (PI / 180.0f);
+    Vector3 dest = {
+        playerPos.x + std::sin(rad) * distance,
+        playerPos.y + yOffset,
+        playerPos.z + std::cos(rad) * distance
+    };
+    return dest;
+}
+
+static bool nudgeCompanionInFrontOfPlayer(const char* reason) {
+    logEnter("visibility_nudge");
+    if (!actorValid(g_companion)) {
+        logExit("visibility_nudge", "FAILED reason=invalid_companion");
+        return false;
+    }
+    Vector3 playerPos = {};
+    float heading = 0.0f;
+    Actor player = playerActor(&playerPos, &heading, nullptr);
+    if (!actorValid(player)) {
+        logExit("visibility_nudge", "FAILED reason=invalid_player");
+        return false;
+    }
+    Vector3 dest = companionPointInFront(playerPos, heading, g_config.spawnDistance, g_config.spawnZOffset);
+    nativeInvoke<void>(0x2D54B916ULL, g_companion, &dest, TRUE, TRUE, TRUE);
+    nativeInvoke<void>(0xECE8520BULL, g_companion, heading, TRUE);
+    g_companionPos = dest;
+    std::ostringstream ok;
+    ok << "OK reason=" << reason << " actor=" << g_companion
+       << " player=" << playerPos.x << "," << playerPos.y << "," << playerPos.z
+       << " dest=" << dest.x << "," << dest.y << "," << dest.z
+       << " heading=" << heading;
+    logExit("visibility_nudge", ok.str().c_str());
+    return true;
+}
