+static bool nudgeCompanionInFrontOfPlayer(const char* reason) {
+    logEnter("visibility_nudge");
+    if (!g_config.visibilityNudgeEnabled) {
+        logExit("visibility_nudge", "SKIPPED config_disabled");
+        return false;
+    }
+    if (!actorValid(g_companion)) {
+        logExit("visibility_nudge", "FAILED reason=invalid_companion");
+        return false;
+    }
+    Vector3 playerPos = {};
+    float heading = 0.0f;
+    Actor player = playerActor(&playerPos, &heading, nullptr);
+    if (!actorValid(player)) {
+        logExit("visibility_nudge", "FAILED reason=invalid_player");
+        return false;
+    }
+    float rad = heading * (PI / 180.0f);
+    Vector3 dest = {
+        playerPos.x + std::sin(rad) * g_config.spawnDistance,
+        playerPos.y + std::cos(rad) * g_config.spawnDistance,
+        playerPos.z + g_config.spawnZOffset
+    };
+    nativeInvoke<void>(0x2D54B916ULL, g_companion, &dest, TRUE, TRUE, TRUE);
+    nativeInvoke<void>(0xECE8520BULL, g_companion, heading, TRUE);
+    g_companionPos = dest;
+    std::ostringstream ok;
+    ok << "OK reason=" << reason << " actor=" << g_companion
+       << " x=" << dest.x << " y=" << dest.y << " z=" << dest.z;
+    logExit("visibility_nudge", ok.str().c_str());
+    return true;
+}
