{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CodeRED Script Workshop GUI",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/related_apps/CodeRED_Script_Workshop/CodeRED_Script_Workshop.py",
      "args": ["gui"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "CodeRED Script Workshop Scan",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/related_apps/CodeRED_Script_Workshop/CodeRED_Script_Workshop.py",
      "args": ["scan", "--refresh"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
