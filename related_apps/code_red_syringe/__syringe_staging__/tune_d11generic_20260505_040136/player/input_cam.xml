<?xml version="1.0" encoding="UTF-8"?>
<sagPlayerInputFile>
	<sagPlayerInput Name="Config1">
		<sagPlayerMapper Name="Camera">
			<Map Value="CamX"                  Source="IOMS_ANALOGUE_GAME_ACTION"  Parameter="@CAMERA.MOVE_X"        Port="-1" Inverted="F"/>
			<Map Value="CamY"                  Source="IOMS_ANALOGUE_GAME_ACTION"  Parameter="@CAMERA.MOVE_Y"        Port="-1" Inverted="F"/>
			<Map Value="LookBack"              Source="IOMS_DIGITAL_GAME_ACTION"   Parameter="@CAMERA.LOOK_BACK"     Port="-1" Inverted="F"/>
      		<Map Value="SwitchCameraModeLeft"  Source="IOMS_DIGITAL_GAME_ACTION"   Parameter="@CAMERA.SWITCH_LEFT"   Port="-1" Inverted="F"/>
      		<Map Value="SwitchCameraModeRight" Source="IOMS_DIGITAL_GAME_ACTION"   Parameter="@CAMERA.SWITCH_RIGHT"  Port="-1" Inverted="F"/>
			<Map Value="FocusCamera" Source="IOMS_DIGITAL_GAME_ACTION" Parameter="@GENERIC.LOOK_AT" Port="-1" Inverted="F"/>
		</sagPlayerMapper>
	</sagPlayerInput>
</sagPlayerInputFile>

